--- scripts/simulation/allocation-sim.mjs:1 ---
   1: #!/usr/bin/env node
   2: // Agent-based simulation of attention-constrained citizen allocation.
   3: // Implements Model 3 of research/formal-models.md and tests predictions
   4: // P1 (funding caps tame salience cascades), P2 (need-weighted defaults
   5: // anchor allocation quality at low attention), and P3 (participation decay
   6: // degrades gracefully only when the released share flows to defaults).
   7: //
   8: // Design: N citizens allocate one unit per cycle across a persistent pool
   9: // of projects with independent-ish quality theta, salience s, and planning
  10: // need-weights w. Citizens act as evaluators (sample projects, pick best
  11: // theta), salience followers (choose proportional to salience plus social
  12: // proof), or default followers (planning weights). Funding-target closure
  13: // optionally refuses contributions beyond a project's target, re-routing
  14: // them to the contributor's next choice.
  15: //
  16: // No dependencies; deterministic under --seed. Usage:
  17: //   node scripts/simulation/allocation-sim.mjs [--runs 20] [--seed 1]
  18: 
  19: const args = Object.fromEntries(
  20:   process.argv.slice(2).map((a, i, arr) => (a.startsWith("--") ? [a.slice(2), arr[i + 1]] : null)).filter(Boolean),
  21: );
  22: const RUNS = parseInt(args.runs ?? "20", 10);
  23: const BASE_SEED = parseInt(args.seed ?? "1", 10);
  24: 
  25: // --- deterministic PRNG (mulberry32) ---------------------------------------
  26: const mulberry32 = (seed) => () => {
  27:   seed |= 0;
  28:   seed = (seed + 0x6d2b79f5) | 0;
  29:   let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
  30:   t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
