### scripts/simulation/e5-sp-symmetry-gate.mjs
    1: #!/usr/bin/env node
    2: // SYMMETRY GATE (go/no-go) — pre-registered in audits/2026-07-10/symmetry-gate-preregistration.md.
    3: // Designed by the independent auditor (Codex) to be adversarial. Selection-only test (delivery at parity).
    4: //
    5: // Both arms share: candidate pool, exact costs, budget, truth net=S-h*cost, report noise ~N(0,tau),
    6: // greedy budget rule, and eligibility by each arm's OWN noisy estimate (hatNet>0). No oracle gate.
    7: //   DISTRIBUTED: endogenous coverage — interested citizen reports w.p. p (v>=0) or p*(1-beta) (v<0);
    8: //                hatS_D = sum(reports)/p.  (adverse voice bias preserved: negatives under-counted)
    9: //   CENTRAL:     competent value-reader, appraisal budget = distributed's EXPECTED #reports, spread
   10: //                EVENLY across projects (fixed bandwidth); hatS_C = reach*mean(sampled reports);
   11: //                score = (1-lambda)*z(hatNet_C/cost) + lambda*z(P/cost). Credit biases RANKING, not eligibility.
   12: //   ORACLE:      full-information greedy on true net/cost.
   13: // Delta=(D-C)/O on TRUE net delivered. GO/NO-GO evaluated against the frozen pre-registration.
   14: 
   15: // ---- deterministic primitives (copied verbatim from e5-sp-model.mjs) ----
   16: function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296};}
   17: function seedFor(a,b){ let h=(a>>>0); h=Math.imul(h^0x9e3779b9,0x85ebca6b); h^=(b>>>0); h=Math.imul(h^(h>>>13),0xc2b2ae35); return (h^(h>>>16))>>>0; }
   18: function mkGauss(rng){ let s=null; return ()=>{ if(s!==null){const t=s;s=null;return t;} let u=0,v=0;while(u===0)u=rng();while(v===0)v=rng();const r=Math.sqrt(-2*Math.log(u)),a=2*Math.PI*v;s=r*Math.sin(a);return r*Math.cos(a);}; }
   19: function corr(x,y){ const n=x.length; let mx=0,my=0; for(let i=0;i<n;i++){mx+=x[i];my+=y[i];} mx/=n;my/=n;
   20:   let sxy=0,sxx=0,syy=0; for(let i=0;i<n;i++){const dx=x[i]-mx,dy=y[i]-my; sxy+=dx*dy;sxx+=dx*dx;syy+=dy*dy;} return sxy/Math.sqrt(sxx*syy); }
   21: function bootDelta(d,c,o,lo,hi,B=4000){ const n=d.length, rng=mulberry32(13579), rs=new Array(B);
   22:   for(let b=0;b<B;b++){ let sd=0,sc=0,so=0; for(let i=0;i<n;i++){const k=(rng()*n)|0; sd+=d[k];sc+=c[k];so+=o[k];} rs[b]=(sd-sc)/so; }
   23:   rs.sort((a,b)=>a-b); const pk=x=>rs[Math.max(0,Math.min(B-1,Math.round(x*(B-1))))]; return {lo:pk(lo),hi:pk(hi)}; }
   24: const sum=a=>a.reduce((p,x)=>p+x,0);
   25: const mean=a=>a.length? sum(a)/a.length : 0;
   26: function median(a){ const b=[...a].sort((x,y)=>x-y); const n=b.length; if(!n) return 0; return n%2? b[(n-1)/2] : (b[n/2-1]+b[n/2])/2; }
   27: function zscore(a){ const m=mean(a); let s=0; for(const x of a) s+=(x-m)*(x-m); s=Math.sqrt(s/(a.length||1))||1; return a.map(x=>(x-m)/s); }
   28: 
   29: // ---- world params (canonical faithful-split; FROZEN) ----
   30: const WP={ N:5000, K:500, mean:0.27, sd:1.0, projSpread:0.15, costHi:10, muF:-4, sigF:1.5, sigP:1.0, eta:0.1, budgetFrac:1/3 };
   31: 
   32: // buildWorld: copied verbatim from e5-sp-model.mjs (truth generation identical) ----
   33: function buildWorld(seed, rho){
   34:   const {N,K,mean,sd,projSpread,costHi}=WP;
   35:   const rng=mulberry32(seedFor(seed, 999)); const g=mkGauss(rng);
   36:   const interested=Array.from({length:K},()=>[]); const cost=new Float64Array(K);
   37:   const S=new Float64Array(K), P=new Float64Array(K), reachA=new Float64Array(K);
   38:   const rc=Math.sqrt(Math.max(0,1-rho*rho)), {muF,sigF,sigP}=WP;
   39:   for(let j=0;j<K;j++){
   40:     cost[j]=1+(costHi-1)*rng();
   41:     const a=g();
   42:     const frac=Math.min(0.9, Math.max(0.005, Math.exp(muF+sigF*a)));
   43:     const projQual=mean+projSpread*g();
   44:     const cLat=rho*a+rc*g();
   45:     let reach=0, sSum=0;
   46:     for(let i=0;i<N;i++){ if(rng()<frac){ const v=projQual+sd*g(); interested[j].push(v); reach++; sSum+=v; } }
   47:     S[j]=sSum; P[j]=Math.exp(sigP*cLat); reachA[j]=reach;
   48:   }
   49:   return {interested,cost,S,P,reach:reachA};
   50: }
   51: 
   52: // greedy fill: rank eligible projects by score desc, take while budget allows (exact costs) ----
   53: function greedy(score, eligible, cost, K, budget){
   54:   const idx=Array.from({length:K},(_,j)=>j).filter(j=>eligible[j]).sort((a,b)=>score[b]-score[a]);
   55:   const chosen=[]; let sp=0;
   56:   for(const j of idx){ if(sp+cost[j]<=budget){ chosen.push(j); sp+=cost[j]; } }
   57:   return chosen;
   58: }
   59: 
   60: // one world under (lambda,h,p,beta,tau) ----
   61: function evalWorld(seed, rho, lambda, h, p, beta, tau){
   62:   const {K,budgetFrac}=WP;
   63:   const W=buildWorld(seed,rho); const {interested,cost,S,P,reach}=W;
   64:   let tot=0; for(let j=0;j<K;j++) tot+=cost[j]; const budget=tot*budgetFrac;
   65:   const net=new Float64Array(K); for(let j=0;j<K;j++) net[j]=S[j]-h*cost[j];
   66:   const rd=mulberry32(seedFor(seed, 4242)); const gd=mkGauss(mulberry32(seedFor(seed, 7777)));
   67: 
   68:   // DISTRIBUTED: endogenous participation sample; estimate hatS_D = sum(reports)/p
   69:   const hatNetD=new Float64Array(K), scoreD=new Float64Array(K), eligD=new Array(K).fill(false);
   70:   let expReports=0;                                   // expected TOTAL distributed reports (for the central's budget)
   71:   for(let j=0;j<K;j++){
   72:     let sumR=0;
   73:     for(const v of interested[j]){ const pp = v<0 ? p*(1-beta) : p; expReports += pp; if(rd()<pp) sumR += v + tau*gd(); }
   74:     const hatS = sumR/p; hatNetD[j]=hatS - h*cost[j]; scoreD[j]=hatNetD[j]/cost[j]; eligD[j]=hatNetD[j]>0;
   75:   }
   76: 
   77:   // CENTRAL: same TOTAL appraisal budget as distributed, spread EVENLY (fixed bandwidth per project)
   78:   const mC=Math.max(1, Math.round(expReports/K));
   79:   const hatNetC=new Float64Array(K), eligC=new Array(K).fill(false);
   80:   const valPerCost=new Float64Array(K), credPerCost=new Float64Array(K);
   81:   for(let j=0;j<K;j++){
   82:     const list=interested[j];
   83:     let obs=0;
   84:     if(list.length>0){ for(let s=0;s<mC;s++){ const v=list[(rd()*list.length)|0]; obs += v + tau*gd(); } obs/=mC; }
   85:     const hatS = reach[j]*obs;                          // central knows reach; unbiased but noisy
   86:     hatNetC[j]=hatS - h*cost[j]; eligC[j]=hatNetC[j]>0;
   87:     valPerCost[j]=hatNetC[j]/cost[j]; credPerCost[j]=P[j]/cost[j];
   88:   }
   89:   const z1=zscore(Array.from(valPerCost)), z2=zscore(Array.from(credPerCost));
   90:   const scoreC=new Float64Array(K); for(let j=0;j<K;j++) scoreC[j]=(1-lambda)*z1[j]+lambda*z2[j];
   91: 
   92:   // ORACLE: full-information greedy on true net/cost
   93:   const scoreO=new Float64Array(K), eligO=new Array(K).fill(false);
   94:   for(let j=0;j<K;j++){ scoreO[j]=net[j]/cost[j]; eligO[j]=net[j]>0; }
   95: 
   96:   const fD=greedy(scoreD,eligD,cost,K,budget), fC=greedy(scoreC,eligC,cost,K,budget), fO=greedy(scoreO,eligO,cost,K,budget);
   97:   const val=(set)=>{ let s=0; for(const j of set) s+=net[j]; return s; };   // delivered TRUE net, f=1.0
   98:   const D=val(fD), C=val(fC), O=val(fO);
   99:   return {D,C,O,S,P};
  100: }
  101: 
  102: // ---- run a cell (100 worlds) ----
  103: const SEEDBASE=20260710, WORLDS=100;
  104: function cell(rho,lambda,h,p,beta,tau){
  105:   const D=[],C=[],O=[],Delta=[]; let SS=[],PP=[];
  106:   for(let i=0;i<WORLDS;i++){
  107:     const r=evalWorld(SEEDBASE+i, rho, lambda, h, p, beta, tau);
  108:     D.push(r.D); C.push(r.C); O.push(r.O); Delta.push((r.D-r.C)/r.O);
  109:     if(i<8){ SS=SS.concat(Array.from(r.S)); PP=PP.concat(Array.from(r.P)); }  // corr(S,P) below is an 8-WORLD DIAGNOSTIC only (kept frozen for reproducibility); it is NOT a decision quantity — cell membership and the gate use latent rho, not this corr, so the NO-GO verdict is unaffected. Full-100-world corr differs by <=0.02.
  110:   }
  111:   const b=bootDelta(D,C,O,0.025,0.975);
  112:   return { rho,lambda,h, corrSP:corr(SS,PP), meanDelta:mean(Delta), medianDelta:median(Delta),
  113:            lo:b.lo, hi:b.hi, D,C,O,Delta, pass:mean(Delta)>0 };
  114: }
  115: 
  116: const REG={ base:{p:0.35,beta:0.30,tau:0.5}, adv:{p:0.15,beta:0.60,tau:1.0} };
  117: const LAMBDAS=[0,0.1,0.2,0.3], RHOS=[0,0.5,1], HS=[1.5,2.5,4];
  118: 
  119: console.log("SYMMETRY GATE — selection-only, delivery at parity (f=1.0). "+WORLDS+" worlds, seedBase="+SEEDBASE+".");
  120: console.log("Both arms: same pool/costs/budget/noise; own noisy eligibility (no oracle gate). Central: value-reader + bounded credit (lambda), even appraisal bandwidth.\n");
  121: 
  122: function runRegime(name, R){
  123:   console.log("=== "+name.toUpperCase()+" regime (p="+R.p+", beta="+R.beta+", tau="+R.tau+") ===");
  124:   console.log("  lam | rho | corrSP(8w diag) |  h  | mean D | med D  |  95% CI          | cell");
  125:   const cells={};
  126:   for(const lam of LAMBDAS) for(const rho of RHOS) for(const h of HS){
  127:     const c=cell(rho,lam,h,R.p,R.beta,R.tau); cells[[lam,rho,h].join(",")]=c;
  128:     const f=x=>(x>=0?"+":"")+x.toFixed(3);
  129:     console.log("  "+lam.toFixed(1)+" | "+rho.toFixed(1)+" | "+c.corrSP.toFixed(2).padStart(5)+"  | "+h.toString().padStart(3)+" | "+f(c.meanDelta).padStart(6)+" | "+f(c.medianDelta).padStart(6)+" | ["+f(c.lo)+","+f(c.hi)+"]".padEnd(6)+" | "+(c.pass?"D>C":"---"));
  130:   }
  131:   console.log("");
  132:   return cells;
  133: }
  134: const baseCells=runRegime("base", REG.base);
  135: const advCells =runRegime("adversarial", REG.adv);
  136: 
  137: // ---- pre-registered gate evaluation ----
  138: function pool(cells, lams, rhos){ const D=[],C=[],O=[],Delta=[]; let n=0,posCells=0;
  139:   for(const lam of lams) for(const rho of rhos) for(const h of HS){ const c=cells[[lam,rho,h].join(",")];
  140:     D.push(...c.D); C.push(...c.C); O.push(...c.O); Delta.push(...c.Delta); n++; if(c.meanDelta>0) posCells++; }
  141:   return {D,C,O,Delta,n,posCells}; }
