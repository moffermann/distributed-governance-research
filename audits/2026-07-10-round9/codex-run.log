17:function median(a){ const b=[...a].sort((x,y)=>x-y); const n=b.length; if(!n) return 0; return n%2? b[(n-1)/2] : (b[n/2-1]+b[n/2])/2; }
18:function zscore(a){ const m=mean(a); let s=0; for(const x of a) s+=(x-m)*(x-m); s=Math.sqrt(s/(a.length||1))||1; return a.map(x=>(x-m)/s); }
