97:  for(let d=0;d<10;d++){ const lo=Math.floor(d*n/10), hi=Math.floor((d+1)*n/10); let se=0,rr=0;
98:    for(let k=lo;k<hi;k++){ se+=recs[k].err*recs[k].err; rr+=recs[k].reach; }
