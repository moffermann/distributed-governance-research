20:const WP={ N:5000, K:500, mean:0.27, sd:1.0, projSpread:0.15, costHi:10, muF:-4, sigF:1.5, sigP:1.0, budgetFrac:1/3 };
21:function buildWorld(seed, rho){
22:  const {N,K,mean,sd,projSpread,costHi}=WP;
23:  const rng=mulberry32(seedFor(seed, 999)); const g=mkGauss(rng);
24:  const interested=Array.from({length:K},()=>[]); const cost=new Float64Array(K);
25:  const S=new Float64Array(K), P=new Float64Array(K), reachA=new Float64Array(K);
26:  const rc=Math.sqrt(Math.max(0,1-rho*rho)), {muF,sigF,sigP}=WP;
27:  for(let j=0;j<K;j++){
28:    cost[j]=1+(costHi-1)*rng();
29:    const a=g();
30:    const frac=Math.min(0.9, Math.max(0.005, Math.exp(muF+sigF*a)));
31:    const projQual=mean+projSpread*g();
32:    const cLat=rho*a+rc*g();
33:    let reach=0, sSum=0;
34:    for(let i=0;i<N;i++){ if(rng()<frac){ const v=projQual+sd*g(); interested[j].push(v); reach++; sSum+=v; } }
35:    S[j]=sSum; P[j]=Math.exp(sigP*cLat); reachA[j]=reach;
36:  }
37:  return {interested,cost,S,P,reach:reachA};
38:}
39:function greedy(score, eligible, cost, K, budget){
40:  const idx=Array.from({length:K},(_,j)=>j).filter(j=>eligible[j]).sort((a,b)=>score[b]-score[a]);
41:  const chosen=[]; let sp=0; for(const j of idx){ if(sp+cost[j]<=budget){ chosen.push(j); sp+=cost[j]; } } return chosen;
42:}
43:// eval one world; centralAlloc in {'even','propreach'}. Returns D,C,O and per-project central appraisal error.
44:function evalWorld(seed, rho, lambda, h, p, beta, tau, centralAlloc){
45:  const {K,budgetFrac}=WP;
46:  const W=buildWorld(seed,rho); const {interested,cost,S,P,reach}=W;
47:  let tot=0; for(let j=0;j<K;j++) tot+=cost[j]; const budget=tot*budgetFrac;
48:  const net=new Float64Array(K); for(let j=0;j<K;j++) net[j]=S[j]-h*cost[j];
49:  const rd=mulberry32(seedFor(seed, 4242)); const gd=mkGauss(mulberry32(seedFor(seed, 7777)));
50:  // distributed
51:  const scoreD=new Float64Array(K), eligD=new Array(K).fill(false); let expReports=0;
52:  for(let j=0;j<K;j++){ let sumR=0;
53:    for(const v of interested[j]){ const pp=v<0?p*(1-beta):p; expReports+=pp; if(rd()<pp) sumR+=v+tau*gd(); }
54:    const hatS=sumR/p; const hn=hatS-h*cost[j]; scoreD[j]=hn/cost[j]; eligD[j]=hn>0; }
55:  // central appraisal budget = expected distributed reports; allocated EVEN or PROP-REACH
56:  const totReach=sum(Array.from(reach))||1;
57:  const hatSC=new Float64Array(K), eligC=new Array(K).fill(false), vpc=new Float64Array(K), cpc=new Float64Array(K);
58:  for(let j=0;j<K;j++){
59:    const list=interested[j];
60:    const mC = centralAlloc==='propreach' ? Math.max(1, Math.round(expReports*reach[j]/totReach))
61:                                           : Math.max(1, Math.round(expReports/K));
62:    let obs=0; if(list.length>0){ for(let s=0;s<mC;s++){ const v=list[(rd()*list.length)|0]; obs+=v+tau*gd(); } obs/=mC; }
63:    const hS=reach[j]*obs; hatSC[j]=hS; const hn=hS-h*cost[j]; eligC[j]=hn>0; vpc[j]=hn/cost[j]; cpc[j]=P[j]/cost[j];
64:  }
65:  const z1=zscore(Array.from(vpc)), z2=zscore(Array.from(cpc));
66:  const scoreC=new Float64Array(K); for(let j=0;j<K;j++) scoreC[j]=(1-lambda)*z1[j]+lambda*z2[j];
67:  const scoreO=new Float64Array(K), eligO=new Array(K).fill(false);
68:  for(let j=0;j<K;j++){ scoreO[j]=net[j]/cost[j]; eligO[j]=net[j]>0; }
69:  const val=set=>{ let s=0; for(const j of set) s+=net[j]; return s; };
70:  const D=val(greedy(scoreD,eligD,cost,K,budget)), C=val(greedy(scoreC,eligC,cost,K,budget)), O=val(greedy(scoreO,eligO,cost,K,budget));
71:  return {D,C,O,reach,S,hatSC};
72:}
