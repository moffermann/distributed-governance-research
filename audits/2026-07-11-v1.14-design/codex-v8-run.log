"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import { baseConfig } from './scripts/simulation/e4-v5/contract.mjs';
import { estimand, makeRng } from './scripts/simulation/e4-v5/engine.mjs';
import { PROBABLE, PRO_CENTRAL, PRO_DIST, SCENARIO_WORLD } from './scripts/simulation/e4-v5/scenario-configs.mjs';
const keys = Object.keys(PROBABLE);
const env = Object.fromEntries(keys.map(k => [k,[Math.min(PROBABLE[k],PRO_CENTRAL[k],PRO_DIST[k]),Math.max(PROBABLE[k],PRO_CENTRAL[k],PRO_DIST[k])]]));
const rng = makeRng(77114);
for (const eps of [0.05,0.10,0.20,0.40]) {
  let neg=0, min=Infinity, max=-Infinity;
  for (let i=0;i<20;i++) {
    const cfg={...baseConfig(),...SCENARIO_WORLD,...PRO_CENTRAL};
    for (const k of keys) {
      const [lo,hi]=env[k]; const away = Math.abs(PRO_CENTRAL[k]-lo) < 1e-12 ? hi : lo;
      cfg[k]=PRO_CENTRAL[k]+eps*rng.u()*(away-PRO_CENTRAL[k]);
    }
    const m=estimand(cfg,{nWorlds:90}).m_hat; if(m<0) neg++; min=Math.min(min,m); max=Math.max(max,m);
  }
  console.log(JSON.stringify({eps,negative:neg,total:20,min,max}));
}
