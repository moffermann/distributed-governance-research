  28: // NULL: both arms near the oracle => negligible gap.
  29: {
  30:   const val = m({ s_exp: 0, b_H_C: 1, a: 0, w: 0, b: 1, sigma_C: 0.02, lambda: 0, beta: 0, p: 1, sigma_e: 0 });
  31:   check('FIX null => |m| negligible', Math.abs(val) < 0.03, `m=${val.toFixed(4)}`);
  32: }
  33: // BOUNDARY: partial myopia + moderate voice => small-magnitude, pipeline must run & stay finite.
  34: {
  35:   const val = m({ s_exp: 1, b_H_C: 0.5, beta: 0.4, lambda: 0.1 });
