  14: const m = (over) => estimand({ ...baseConfig(), ...WORLD, ...over }, { nWorlds: NW }).m_hat;
  15: 
  16: // ---- Acceptance fixtures: ground truth known by construction ----
  17: // STRONG DISTRIBUTED: central near-blind on the long tail (s_exp high), modest voice suppression => distributed wins big.
  18: {
  19:   const val = m({ s_exp: 4, b_H_C: 0.3, beta: 0.3, lambda: 0.15 });
  20:   check('FIX strong-distributed => m materially > 0', val > 0.10, `m=${val.toFixed(3)}`);
  21: }
  22: // STRONG CENTRAL: central competent (gate=1, sees harm, low noise, no credit tilt), distributed crippled
  23: // (opponents silenced, low participation, noisy) => central wins.
