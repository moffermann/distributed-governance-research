  41:   beta:    { value: 0.40, kind: 'physical', dm: [0, 1], df: [0, 1],    ralpha: [0.1, 0.7],  note: 'adverse-voice suppression of opponents' },
  42:   sigma_e: { value: 0.5,  kind: 'physical', dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of report noise' },
  43: 
  44:   // ---- central arm (salience-gated harm myopia) ----
  45:   v_p0:    { value: 0.6,  kind: 'structural',  dm: [-Infinity, Infinity], df: [-5, 5], ralpha: [-0.5, 1.5], note: "planner's own baseline position" },
  46:   gamma:   { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 5],  ralpha: [0.2, 1.2],  note: 'loading of planner projection on category signal g' },
  47:   sigma_v: { value: 0.5,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of projection idiosyncrasy' },
  48:   a:       { value: 0.2,  kind: 'structural',  dm: [-Infinity, Infinity], df: [-5, 5], ralpha: [-0.3, 0.8], note: 'central intercept / systematic level bias' },
  49:   b:       { value: 0.9,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.6, 1.1],  note: 'central responsiveness to SUPPORT S+' },
  50:   w:       { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.2, 1.0],  note: 'directional projection weight' },
  51:   b_H_C:   { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.1, 1.0],  note: 'central harm-detection coefficient (myopia; salience-gated)' },
  52:   s_exp:   { value: 2.0,  kind: 'physical',    dm: [0, Infinity], df: [0.2, 10], ralpha: [1.0, 4.0], note: 'harm-gate exponent: s(V)=V^s_exp (>1 => near-blind on long tail)' },
  53:   sigma_C: { value: 0.5,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of central estimation noise eta' },
  54: 
  55:   // ---- selection ----
  56:   h:       { value: 0.0,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0, 1.0], note: 'opportunity-cost hurdle (shared across arms)' },
  57:   lambda:  { value: 0.15, kind: 'physical',    dm: [0, 1], df: [0, 1], ralpha: [0, 0.4], note: 'central credit-pressure weight' },
  58:   rho_P:   { value: 1.0,  kind: 'structural',  dm: [-Infinity, Infinity], df: [-5, 5], ralpha: [0.5, 2.0], note: 'salience->credit loading' },
  59: };
  60: 
  61: // Aggregation A is NORMATIVE and declared, never randomized into a prior.
  62: export const AGGREGATION = { primary: 'mean', alternatives: ['harm_weighted'], note: 'A=mean primary; harm-weighted is a SEPARATE declared estimand' };
  63: 
  64: // ---- numerical / Monte-Carlo constants (nu_all) ----
  65: export const NUM = {
  66:   n_worlds:       { value: 1500, note: 'Monte-Carlo worlds per theta' },
  67:   seed:           { value: 20260711, note: 'base PRNG seed (Date.now/Math.random forbidden)' },
  68:   bootstrap_reps: { value: 400,  note: 'world-cluster bootstrap replications (inner variability only)' },
  69:   ci_level:       { value: 0.95, note: 'bootstrap CI level' },
  70:   common_random:  { value: true, note: 'common random numbers across arms within a world' },
  71:   z_fallback_sd:  { value: 1.0,  note: 'z-score sd fallback when eligible-set sd=0' },
  72: };
  73: 
  74: // ---- estimand thresholds (frozen, mean-value units; NOT the retired 0.05) ----
  75: export const CLASSIFY = {
  76:   o_min_frac:  { value: 0.05, note: 'o_min = o_min_frac * median(O_W); worlds with O<=o_min excluded from m, counted in pi_deg' },
  77:   delta:       { value: 0.03, note: 'materiality band on m (fraction-of-oracle units); justified in delivered-value terms, NOT the 0.05 rebuild gate' },
  78:   zero_tol:    { value: 0.005, note: 'sign_status=zero-touching when |m|<=zero_tol or CI straddles 0 within this' },
  79:   pi_deg_warn: { value: 0.10, note: 'degeneracy_status=high above this share' },
  80: };
  81: 
  82: // alpha coverage family for the magnitude (R_alpha) layer
  83: export const ALPHA_LEVELS = [0.5, 0.8, 0.95];
  84: 
  85: // ---- CLOSED output schema (embargo-critical): additionalProperties:false; cannot express D/C or ratio-parity-1 ----
  86: export const OUTPUT_SCHEMA = {
  87:   $schema: 'http://json-schema.org/draft-07/schema#',
  88:   type: 'object',
  89:   additionalProperties: false,
  90:   required: ['contract_version', 'theta_id', 'pi_deg', 'm_hat', 'ci', 'sign_status', 'materiality_status', 'degeneracy_status', 'numerical_status'],
  91:   properties: {
  92:     contract_version:   { type: 'string' },
  93:     theta_id:           { type: 'string' },
  94:     pi_deg:             { type: 'number', minimum: 0, maximum: 1 },
  95:     m_hat:              { type: 'number' },                 // E[(D-C)/O | O>o_min], a signed fraction of oracle
  96:     ci:                 { type: 'array', items: { type: 'number' }, minItems: 2, maxItems: 2 },
  97:     m_lo_DF:            { type: 'number' },                 // sign backbone (measure-free over joint D_F)
  98:     m_hi_DF:            { type: 'number' },
  99:     m_Ralpha:           { type: 'object' },                 // magnitude by alpha level (measured over joint R_alpha)
 100:     sign_status:        { enum: ['pos', 'neg', 'zero-touching', 'indeterminate'] },
 101:     materiality_status: { enum: ['material', 'negligible', 'uncertain'] },
 102:     degeneracy_status:  { enum: ['ok', 'high', 'degenerate'] },
 103:     numerical_status:   { enum: ['resolved', 'unresolved'] },
 104:   },
 105:   // NOTE: there is deliberately NO field able to carry D/C, a ratio with parity 1, or an institution-performance
 106:   // multiplier. The render adapter additionally rejects the tokens 'x'/'×'/'D/C' in performance context.
 107: };
 108: 
 109: // Tokens the sole render adapter must reject in institution-performance context (ASCII x, Unicode multiplication, ratio).
 110: export const EMBARGO_TOKENS = ['×', 'D/C', 'C/D'];
 111: 
 112: // ---------- validation: fail-closed on unknown / unused ----------
 113: export function knownThetaKeys() { return new Set(Object.keys(THETA)); }
 114: 
 115: // Throw if a config carries any key not registered in THETA (unknown), or (optionally) if a registered key is
 116: // missing (unused-required). Engines call this before running.
 117: export function validateConfig(cfg, { requireAll = true } = {}) {
 118:   const known = knownThetaKeys();
 119:   const bad = Object.keys(cfg).filter((k) => !known.has(k));
 120:   if (bad.length) throw new Error(`[contract] unknown parameter(s) not in THETA: ${bad.join(', ')}`);
 121:   if (requireAll) {
 122:     const missing = [...known].filter((k) => !(k in cfg));
 123:     if (missing.length) throw new Error(`[contract] missing required parameter(s): ${missing.join(', ')}`);
 124:   }
 125:   for (const [k, v] of Object.entries(cfg)) {
 126:     if (typeof v !== 'number' || Number.isNaN(v)) throw new Error(`[contract] ${k} must be a number, got ${v}`);
 127:     const { dm } = THETA[k];
 128:     if (v < dm[0] || v > dm[1]) throw new Error(`[contract] ${k}=${v} outside mathematical domain [${dm[0]}, ${dm[1]}]`);
 129:   }
 130:   return true;
 131: }
 132: 
 133: // Base config = registered default values.
 134: export function baseConfig() {
 135:   const cfg = {};
 136:   for (const [k, spec] of Object.entries(THETA)) cfg[k] = spec.value;
 137:   return cfg;
 138: }
 139: 
 140: // Deterministic content hash of the frozen sets (so the joint D_F/R_alpha objects and thresholds are pinned before
 141: // any production run). Simple FNV-1a over a canonical JSON — no Date/Math.random.
 142: export function contractHash() {
 143:   const canonical = JSON.stringify({ v: CONTRACT_VERSION, THETA, NUM, CLASSIFY, ALPHA_LEVELS, AGGREGATION });
 144:   let h = 0x811c9dc5;
 145:   for (let i = 0; i < canonical.length; i++) {
 146:     h ^= canonical.charCodeAt(i);
 147:     h = Math.imul(h, 0x01000193) >>> 0;
 148:   }
 149:   return 'fnv1a-' + h.toString(16).padStart(8, '0');
 150: }
 151: 
 152: export const directionalKeys = () => Object.entries(THETA).filter(([, s]) => s.kind === 'directional').map(([k]) => k);
 153: export const physicalKeys    = () => Object.entries(THETA).filter(([, s]) => s.kind === 'physical').map(([k]) => k);
### scripts/simulation/e4-v5/engine.mjs
   1: // E4 v1.14 — fresh mean-scale engine, driven ONLY by the contract.
   2: // Implements DESIGN_SKETCH_v5 §1-§2: anti-value (S = S+ - H), the behavioral coverage estimator (MNAR mean), and
   3: // the central salience-gated harm-myopia model. All value quantities are per-interested-person means. Every literal
   4: // the engine uses comes from the contract; validateConfig() is called before any run (fail-closed).
   5: 
   6: import { THETA, NUM, CLASSIFY, validateConfig } from './contract.mjs';
   7: 
   8: // ---------------- seeded PRNG (Date.now / Math.random forbidden for reproducibility) ----------------
   9: export function makeRng(seed) {
  10:   let s = seed >>> 0;
  11:   const u = () => { // mulberry32
  12:     s |= 0; s = (s + 0x6D2B79F5) | 0;
  13:     let t = Math.imul(s ^ (s >>> 15), 1 | s);
  14:     t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  15:     return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  16:   };
  17:   let spare = null;
  18:   const normal = () => { // Box-Muller with cached spare
  19:     if (spare !== null) { const v = spare; spare = null; return v; }
  20:     let a = u(); if (a < 1e-12) a = 1e-12;
  21:     const b = u();
  22:     const r = Math.sqrt(-2 * Math.log(a)), th = 2 * Math.PI * b;
  23:     spare = r * Math.sin(th);
  24:     return r * Math.cos(th);
  25:   };
  26:   const exponential = (mean) => -mean * Math.log(1 - u() + 1e-12);
  27:   const gamma = (k) => { // Marsaglia-Tsang
  28:     if (k < 1) return gamma(k + 1) * Math.pow(u() + 1e-12, 1 / k);
  29:     const d = k - 1 / 3, c = 1 / Math.sqrt(9 * d);
  30:     for (;;) {
  31:       let x, v;
  32:       do { x = normal(); v = 1 + c * x; } while (v <= 0);
  33:       v = v * v * v;
  34:       const uu = u();
  35:       if (uu < 1 - 0.0331 * x * x * x * x) return d * v;
  36:       if (Math.log(uu + 1e-12) < 0.5 * x * x + d * (1 - v + Math.log(v))) return d * v;
  37:     }
  38:   };
  39:   const beta = (a, b) => { const ga = gamma(a), gb = gamma(b); return ga / (ga + gb); };
  40:   const binomialApprox = (n, prob) => {
  41:     if (n <= 0 || prob <= 0) return 0;
  42:     if (prob >= 1) return n;
  43:     const m = n * prob, sd = Math.sqrt(n * prob * (1 - prob));
  44:     return Math.max(0, Math.min(n, Math.round(m + sd * normal())));
  45:   };
  46:   return { u, normal, exponential, gamma, beta, binomialApprox };
  47: }
  48: 
  49: // ---------------- world generation (one economy of projects) ----------------
  50: // Returns an array of admissible projects, each with true net value S, cost c, and the three arms' signals.
  51: export function generateWorld(cfg, rng) {
  52:   const projects = [];
  53:   for (let j = 0; j < cfg.K; j++) {
  54:     const q = cfg.m_q + cfg.s_q * rng.normal();
  55:     const V = rng.beta(cfg.a_V, cfg.b_V);                       // visibility in [0,1], heavy-tailed toward 0
  56:     const qStd = cfg.s_q > 0 ? (q - cfg.m_q) / cfg.s_q : 0;
  57:     const g = cfg.zeta * qStd + Math.sqrt(Math.max(0, 1 - cfg.zeta * cfg.zeta)) * rng.normal();
  58:     const c = cfg.c_lo + (cfg.c_hi - cfg.c_lo) * rng.u();
  59:     const r = rng.beta(cfg.a_r, cfg.b_r);
  60:     const n = rng.binomialApprox(cfg.N, r);
  61:     if (n === 0) continue;                                      // inadmissible in ALL arms (dropped, counted below)
  62: 
  63:     let sumPos = 0, sumNeg = 0, sumReport = 0;
  64:     for (let i = 0; i < n; i++) {
  65:       let u = q + cfg.sigma * rng.normal();
  66:       if (rng.u() < cfg.pi_opp) u -= rng.exponential(cfg.mu_opp);   // intense-minority opposition
  67:       if (u >= 0) sumPos += u; else sumNeg += -u;
  68:       const reportProb = u >= 0 ? cfg.p : cfg.p * (1 - cfg.beta);
  69:       if (rng.u() < reportProb) sumReport += (u + cfg.sigma_e * rng.normal()) / cfg.p;
  70:     }
  71:     const Splus = sumPos / n;                                   // support (mean of positive parts)
  72:     const H = sumNeg / n;                                       // harm (mean opposition intensity)
  73:     const S = Splus - H;                                        // true net value (mean scale)
  74:     const M_D = sumReport / n;                                  // behavioral coverage estimator; E[M_D|u]=S+ -(1-beta)H
  75: 
  76:     const v_pj = cfg.v_p0 + cfg.gamma * g + cfg.sigma_v * rng.normal();
  77:     const sV = Math.pow(Math.max(0, Math.min(1, V)), cfg.s_exp);// harm gate: ~0 on long tail, ~1 when salient
  78:     const M_C = cfg.a + cfg.b * Splus + cfg.w * (v_pj - Splus) - cfg.b_H_C * sV * H + cfg.sigma_C * rng.normal();
  79: 
  80:     const P = cfg.rho_P * V;                                    // visible salience -> credit
  81:     projects.push({ S, c, M_C, M_D, P });
  82:   }
  83:   return projects;
  84: }
  85: 
  86: // ---------------- selection: one common interface for all three arms ----------------
  87: function zscore(vals, fallbackSd) {
  88:   const n = vals.length;
  89:   if (n === 0) return [];
  90:   const mean = vals.reduce((s, x) => s + x, 0) / n;
  91:   let v = 0; for (const x of vals) v += (x - mean) * (x - mean);
  92:   let sd = Math.sqrt(v / n);
  93:   if (!(sd > 0)) sd = fallbackSd;
  94:   return vals.map((x) => (x - mean) / sd);
  95: }
  96: 
  97: // Fund greedily by rank score among the arm's own eligible set, under budget, exact residual fill, tie-break lower j.
  98: function fundedValue(projects, signalKey, cfg, budget, opts = {}) {
  99:   const idx = [];
 100:   for (let j = 0; j < projects.length; j++) {
 101:     const x = projects[j][signalKey];
 102:     if (x - cfg.h * projects[j].c > 0) idx.push(j);            // own-estimate eligibility gate
 103:   }
 104:   if (idx.length === 0) return 0;
 105:   const rawVal = idx.map((j) => (projects[j][signalKey] - cfg.h * projects[j].c) / projects[j].c);
 106:   let score = zscore(rawVal, NUM.z_fallback_sd.value);
 107:   if (opts.creditTilt) {                                        // central credit tilt
 108:     const zP = zscore(idx.map((j) => projects[j].P / projects[j].c), NUM.z_fallback_sd.value);
 109:     score = score.map((s, t) => (1 - cfg.lambda) * s + cfg.lambda * zP[t]);
 110:   }
 111:   const order = idx.map((j, t) => ({ j, s: score[t] }))
 112:     .sort((A, B) => (B.s - A.s) || (A.j - B.j));               // desc score, tie-break lower index
 113:   let spent = 0, delivered = 0;
 114:   for (const { j } of order) {
 115:     if (spent + projects[j].c <= budget) { spent += projects[j].c; delivered += projects[j].S; }
 116:   }
 117:   return delivered;
 118: }
 119: 
 120: export function runWorld(cfg, rng) {
 121:   const projects = generateWorld(cfg, rng);
 122:   if (projects.length === 0) return { D: 0, C: 0, O: 0, empty: true };
 123:   let totalCost = 0; for (const pr of projects) totalCost += pr.c;
 124:   const budget = cfg.phi * totalCost;
 125:   const O = fundedValue(projects, 'S',   cfg, budget);
 126:   const C = fundedValue(projects, 'M_C', cfg, budget, { creditTilt: true });
 127:   const D = fundedValue(projects, 'M_D', cfg, budget);
 128:   return { D, C, O, empty: false };
 129: }
 130: 
 131: // ---------------- estimand m(theta) = E[(D-C)/O | O>o_min], plus pi_deg ----------------
 132: function median(arr) {
 133:   if (arr.length === 0) return 0;
 134:   const a = [...arr].sort((x, y) => x - y);
 135:   const mid = a.length >> 1;
 136:   return a.length % 2 ? a[mid] : 0.5 * (a[mid - 1] + a[mid]);
 137: }
 138: 
 139: export function estimand(cfg, { nWorlds = NUM.n_worlds.value, seed = NUM.seed.value } = {}) {
 140:   validateConfig(cfg);
 141:   const rng = makeRng(seed);
 142:   const worlds = [];
 143:   for (let wI = 0; wI < nWorlds; wI++) {
 144:     const { D, C, O, empty } = runWorld(cfg, rng);
 145:     if (!empty) worlds.push({ D, C, O });
 146:   }
 147:   const Os = worlds.map((x) => x.O);
 148:   const o_min = CLASSIFY.o_min_frac.value * median(Os);
 149:   const kept = worlds.filter((x) => x.O > o_min);
 150:   const degCount = worlds.length - kept.length;
 151:   const pi_deg = worlds.length ? degCount / worlds.length : 1;
 152:   const ratios = kept.map((x) => (x.D - x.C) / x.O);
 153:   const m_hat = ratios.length ? ratios.reduce((s, r) => s + r, 0) / ratios.length : NaN;
 154: 
 155:   // world-cluster bootstrap CI (inner simulation variability only)
 156:   const B = NUM.bootstrap_reps.value;
 157:   const bootRng = makeRng((seed ^ 0x9e3779b9) >>> 0);
 158:   const boots = [];
 159:   if (ratios.length) {
 160:     for (let bI = 0; bI < B; bI++) {
 161:       let acc = 0;
 162:       for (let t = 0; t < ratios.length; t++) acc += ratios[Math.floor(bootRng.u() * ratios.length)];
 163:       boots.push(acc / ratios.length);
 164:     }
 165:     boots.sort((a, b) => a - b);
 166:   }
 167:   const lo = boots.length ? boots[Math.floor((1 - NUM.ci_level.value) / 2 * boots.length)] : NaN;
 168:   const hi = boots.length ? boots[Math.floor((1 + NUM.ci_level.value) / 2 * boots.length) - 1] : NaN;
 169: 
 170:   return { m_hat, ci: [lo, hi], pi_deg, n_kept: kept.length, n_worlds: worlds.length, o_min };
 171: }
### scripts/simulation/e4-v5/schema.mjs
   1: // E4 v1.14 — minimal closed-schema validator (no external deps). Enforces additionalProperties:false, required
   2: // fields, and enums from the contract's OUTPUT_SCHEMA. The schema deliberately has NO field able to carry D/C or a
   3: // ratio-with-parity-1; this validator guarantees no extra field sneaks one in.
   4: import { OUTPUT_SCHEMA } from './contract.mjs';
   5: 
   6: export function validateOutput(obj) {
   7:   const S = OUTPUT_SCHEMA, errs = [];
   8:   if (typeof obj !== 'object' || obj === null) return ['output is not an object'];
   9:   for (const k of Object.keys(obj)) {
  10:     if (!(k in S.properties)) errs.push(`forbidden extra field: ${k}`); // additionalProperties:false
  11:   }
  12:   for (const k of S.required) if (!(k in obj)) errs.push(`missing required field: ${k}`);
  13:   for (const [k, spec] of Object.entries(S.properties)) {
  14:     if (!(k in obj)) continue;
  15:     const v = obj[k];
  16:     if (spec.enum && !spec.enum.includes(v)) errs.push(`${k}=${JSON.stringify(v)} not in enum ${JSON.stringify(spec.enum)}`);
  17:     if (spec.type === 'number' && typeof v !== 'number') errs.push(`${k} must be number`);
  18:     if (spec.type === 'string' && typeof v !== 'string') errs.push(`${k} must be string`);
  19:     if (spec.type === 'array') {
  20:       if (!Array.isArray(v)) errs.push(`${k} must be array`);
  21:       else if (spec.minItems && v.length < spec.minItems) errs.push(`${k} too short`);
  22:       else if (spec.maxItems && v.length > spec.maxItems) errs.push(`${k} too long`);
  23:     }
  24:     if (spec.minimum !== undefined && v < spec.minimum) errs.push(`${k} below minimum`);
  25:     if (spec.maximum !== undefined && v > spec.maximum) errs.push(`${k} above maximum`);
  26:   }
  27:   return errs;
  28: }
### scripts/simulation/e4-v5/adapter.mjs
   1: // E4 v1.14 — the SOLE render adapter (mechanical embargo). Every official artifact must render through here.
   2: // It (a) validates against the closed schema, and (b) rejects any institution-performance multiplier notation:
   3: // ASCII 'x'/'X' as a multiplier suffix on a number, the Unicode multiplication sign, and bare 'D/C'/'C/D' ratios.
   4: // m_hat is a SIGNED FRACTION of the oracle (parity at 0), never a ratio-with-parity-1 and never suffixed with 'x'.
   5: import { EMBARGO_TOKENS } from './contract.mjs';
   6: import { validateOutput } from './schema.mjs';
   7: 
   8: // reject "2.2x", "2.2X", "×", "D/C", "C/D" appearing in rendered performance text
   9: const MULT_SUFFIX = /\d\s*[xX×]\b/;              // a number immediately followed by x/X/× (multiplier notation)
  10: const RATIO_TOKEN = /\b[DC]\s*\/\s*[CD]\b/;      // D/C or C/D
  11: 
  12: export function assertNoEmbargoedTokens(text) {
  13:   const hits = [];
  14:   if (MULT_SUFFIX.test(text)) hits.push('multiplier-suffix (number+x/×)');
  15:   if (RATIO_TOKEN.test(text)) hits.push('institution ratio (D/C or C/D)');
  16:   for (const tok of EMBARGO_TOKENS) if (text.includes(tok)) hits.push(`token '${tok}'`);
  17:   if (hits.length) throw new Error(`[embargo] rendered text contains forbidden performance notation: ${hits.join(', ')}`);
  18:   return true;
  19: }
  20: 
  21: export function renderReport(out) {
  22:   const errs = validateOutput(out);
  23:   if (errs.length) throw new Error(`[embargo] output failed closed schema: ${errs.join('; ')}`);
  24:   const pct = (x) => (100 * x).toFixed(1) + '%';                 // signed fraction of oracle, NOT a multiplier
  25:   const mag = out.m_Ralpha
  26:     ? Object.entries(out.m_Ralpha).map(([al, iv]) => `  α=${al}: [${pct(iv[0])}, ${pct(iv[1])}] of oracle`).join('\n')
  27:     : '  (magnitude layer not computed)';
  28:   const text = [
  29:     `E4 evidence — contract ${out.contract_version} — θ:${out.theta_id}`,
  30:     `  m̂ (signed fraction of full-information oracle, parity at 0): ${pct(out.m_hat)}  CI=[${pct(out.ci[0])}, ${pct(out.ci[1])}]`,
  31:     `  sign backbone over D_F (measure-free): [${pct(out.m_lo_DF)}, ${pct(out.m_hi_DF)}]`,
  32:     `  magnitude over R_α (measured):`,
  33:     mag,
  34:     `  status → sign:${out.sign_status}  materiality:${out.materiality_status}  degeneracy:${out.degeneracy_status}  numerical:${out.numerical_status}`,
  35:     `  π_deg (degenerate-world share): ${pct(out.pi_deg)}`,
  36:   ].join('\n');
  37:   assertNoEmbargoedTokens(text);
  38:   return text;
  39: }
### scripts/simulation/e4-v5/evidence.mjs
   1: // E4 v1.14 — the exclusive evidence path (`npm run e4:evidence`). Produces the transport-robust partial-ID result:
   2: // the SIGN backbone measure-free over the joint D_F, the MAGNITUDE over the joint R_alpha (coverage family), the
   3: // point estimate m̂ with CI, the four orthogonal status fields, and a sign-reversal RIVAL sensitivity. Everything
   4: // renders through the sole embargo adapter. Output conforms to the closed schema.
   5: import { THETA, NUM, CLASSIFY, ALPHA_LEVELS, baseConfig, contractHash, CONTRACT_VERSION } from './contract.mjs';
   6: import { estimand } from './engine.mjs';
   7: import { renderReport } from './adapter.mjs';
   8: import { validateOutput } from './schema.mjs';
   9: 
  10: // Evidence world + Monte-Carlo budget (all within D_M; smaller than contract defaults for tractable sweeps).
  11: const WORLD = { N: 900, K: 120 };
  12: const SWEEP_NW = 300, BASE_NW = 600, SEED = NUM.seed.value;
  13: 
  14: // Sign-critical parameters swept for the partial-ID (directional + behavioral). Joint box = independent by default
  15: // (declared dependence: none); corners+center approximate the extrema (documented; refine with an optimizer later).
  16: const SIGN_KEYS = ['w', 'b_H_C', 'beta', 's_exp'];
  17: 
  18: function boxPoints(box) {
  19:   const keys = Object.keys(box), pts = [], n = 1 << keys.length;
  20:   for (let m = 0; m < n; m++) { const p = {}; keys.forEach((k, bi) => { p[k] = (m >> bi & 1) ? box[k][1] : box[k][0]; }); pts.push(p); }
  21:   const c = {}; keys.forEach((k) => { c[k] = 0.5 * (box[k][0] + box[k][1]); }); pts.push(c);
  22:   return pts;
  23: }
  24: function mOverBox(base, box, nWorlds) {
  25:   let lo = Infinity, hi = -Infinity;
  26:   for (const p of boxPoints(box)) {
  27:     const m = estimand({ ...base, ...p }, { nWorlds, seed: SEED }).m_hat;
  28:     if (Number.isFinite(m)) { if (m < lo) lo = m; if (m > hi) hi = m; }
  29:   }
  30:   return { lo, hi };
  31: }
  32: const dfBox   = (keys) => Object.fromEntries(keys.map((k) => [k, [...THETA[k].df]]));
  33: function scaleBand([lo, hi], factor, clip) {
  34:   const c = 0.5 * (lo + hi), h = 0.5 * (hi - lo) * factor;
  35:   return [Math.max(c - h, clip[0]), Math.min(c + h, clip[1])];
  36: }
  37: // coverage family: R_alpha (contract band) is the α=0.8 object; shrink for 0.5, widen for 0.95 (frozen rule).
  38: const ALPHA_FACTOR = { 0.5: 0.6, 0.8: 1.0, 0.95: 1.3 };
  39: const ralphaBox = (keys, alpha) => Object.fromEntries(keys.map((k) => [k, scaleBand(THETA[k].ralpha, ALPHA_FACTOR[alpha], THETA[k].df)]));
  40: 
  41: function classify(m_hat, ci, m_lo_DF, m_hi_DF, pi_deg) {
  42:   const zt = CLASSIFY.zero_tol.value, d = CLASSIFY.delta.value;
  43:   let sign_status;
  44:   if (m_lo_DF > zt) sign_status = 'pos';
  45:   else if (m_hi_DF < -zt) sign_status = 'neg';
  46:   else if (m_lo_DF < -zt && m_hi_DF > zt) sign_status = 'indeterminate';
  47:   else sign_status = 'zero-touching';
  48:   let materiality_status;
  49:   if (ci[0] > d || ci[1] < -d) materiality_status = 'material';
  50:   else if (ci[0] > -d && ci[1] < d) materiality_status = 'negligible';
  51:   else materiality_status = 'uncertain';
  52:   const degeneracy_status = pi_deg >= 1 ? 'degenerate' : (pi_deg > CLASSIFY.pi_deg_warn.value ? 'high' : 'ok');
  53:   const numerical_status = (ci[1] - ci[0]) < d ? 'resolved' : 'unresolved';
  54:   return { sign_status, materiality_status, degeneracy_status, numerical_status };
  55: }
  56: 
  57: export function buildEvidence() {
  58:   const base = { ...baseConfig(), ...WORLD };
  59:   const pt = estimand(base, { nWorlds: BASE_NW, seed: SEED });
  60:   const df = mOverBox(base, dfBox(SIGN_KEYS), SWEEP_NW);
  61:   const m_Ralpha = {};
  62:   for (const al of ALPHA_LEVELS) { const b = mOverBox(base, ralphaBox(SIGN_KEYS, al), SWEEP_NW); m_Ralpha[String(al)] = [b.lo, b.hi]; }
  63: 
  64:   const st = classify(pt.m_hat, pt.ci, df.lo, df.hi, pt.pi_deg);
  65:   const out = {
  66:     contract_version: CONTRACT_VERSION,
  67:     theta_id: 'base+' + contractHash(),
  68:     pi_deg: pt.pi_deg,
  69:     m_hat: pt.m_hat,
  70:     ci: pt.ci,
  71:     m_lo_DF: df.lo,
  72:     m_hi_DF: df.hi,
  73:     m_Ralpha,
  74:     ...st,
  75:   };
  76:   const errs = validateOutput(out);
  77:   if (errs.length) throw new Error('evidence output invalid: ' + errs.join('; '));
  78: 
  79:   // Sign-reversal RIVAL sensitivity (author decision: defend the direction as base case, report reversal, not exclude).
  80:   const rivalBox = { ...dfBox(SIGN_KEYS), w: [-1.5, 3], gamma: [-2, 5] };
  81:   const rival = mOverBox({ ...base, gamma: THETA.gamma.value }, rivalBox, SWEEP_NW);
  82: 
  83:   return { out, rival };
  84: }
  85: 
  86: const { out, rival } = buildEvidence();
  87: console.log(renderReport(out));
  88: console.log(`\n  sign-reversal rival sensitivity (w,γ allowed <0): m ∈ [${(100 * rival.lo).toFixed(1)}%, ${(100 * rival.hi).toFixed(1)}%] of oracle`);
  89: console.log(`  contract hash: ${contractHash()}`);
### scripts/simulation/e4-v5/controls.mjs
   1: // E4 v1.14 — negative controls. These MUST pass or the model is not trustworthy (DESIGN_SKETCH_v5 §5).
   2: // Run: node scripts/simulation/e4-v5/controls.mjs
   3: import { baseConfig } from './contract.mjs';
   4: import { makeRng, runWorld, estimand } from './engine.mjs';
   5: 
   6: const SMALL = { N: 900, K: 120 };            // smaller world for fast, still-meaningful controls (both within D_M)
   7: const NW = 300, SEED = 20260711;
   8: 
   9: // run NW worlds, return per-world {D,C,O} arrays (common random numbers => aligned across configs)
  10: function runWorlds(cfg) {
  11:   const rng = makeRng(SEED);
  12:   const out = [];
  13:   for (let i = 0; i < NW; i++) { const r = runWorld(cfg, rng); if (!r.empty) out.push(r); }
  14:   return out;
  15: }
  16: const maxAbsDiff = (a, b, key) => Math.max(...a.map((x, i) => Math.abs(x[key] - b[i][key])));
  17: const pass = (name, ok, detail) => console.log(`${ok ? 'PASS' : 'FAIL'}  ${name}${detail ? '  — ' + detail : ''}`);
  18: 
  19: let allOk = true;
  20: const check = (name, ok, detail) => { pass(name, ok, detail); allOk = allOk && ok; };
  21: 
  22: // ---- Control 1: signal recovery + exact joint symmetry ----
  23: // a=w=0, b=1, sigma_C=0, b_H_C=1, s_exp=0 (gate=1 everywhere) => M_C = S+ - H = S.
  24: // p=1, beta=0, sigma_e=0 => everyone reports truthfully => M_D = S. All three arms == oracle => D=C=O => m=0.
  25: {
  26:   const cfg = { ...baseConfig(), ...SMALL,
  27:     a: 0, w: 0, b: 1, sigma_C: 0, b_H_C: 1, s_exp: 0, lambda: 0,
  28:     p: 1, beta: 0, sigma_e: 0 };
  29:   const worlds = runWorlds(cfg);
  30:   const maxDC = Math.max(...worlds.map((x) => Math.abs(x.D - x.C)));
  31:   const maxDO = Math.max(...worlds.map((x) => Math.abs(x.D - x.O)));
  32:   const { m_hat } = estimand(cfg, { nWorlds: NW });
  33:   check('C1 signal recovery: M_C=M_D=S => D=C=O', maxDC < 1e-9 && maxDO < 1e-9, `max|D-C|=${maxDC.toExponential(2)}, max|D-O|=${maxDO.toExponential(2)}`);
  34:   check('C1 estimand m == 0', Math.abs(m_hat) < 1e-9, `m=${m_hat.toExponential(2)}`);
  35: }
  36: 
  37: // ---- Control 2: pathway inactivation — credit (lambda=0) ----
  38: // At lambda=0, the credit salience P must not affect central selection: varying rho_P leaves C unchanged world-by-world.
  39: {
  40:   const base = { ...baseConfig(), ...SMALL, lambda: 0 };
  41:   const A = runWorlds({ ...base, rho_P: 1 });
  42:   const Bb = runWorlds({ ...base, rho_P: 5 });
  43:   check('C2 lambda=0 => credit P inert', maxAbsDiff(A, Bb, 'C') < 1e-9, `max|dC|=${maxAbsDiff(A, Bb, 'C').toExponential(2)}`);
  44: }
  45: 
  46: // ---- Control 3: pathway inactivation — projection (w=0) ----
  47: // At w=0, the planner position v_p must not affect M_C: varying v_p0 leaves C unchanged world-by-world.
  48: {
  49:   const base = { ...baseConfig(), ...SMALL, w: 0 };
  50:   const A = runWorlds({ ...base, v_p0: 0.6 });
  51:   const Bb = runWorlds({ ...base, v_p0: 3.0 });
  52:   check('C3 w=0 => planner position inert', maxAbsDiff(A, Bb, 'C') < 1e-9, `max|dC|=${maxAbsDiff(A, Bb, 'C').toExponential(2)}`);
  53: }
  54: 
  55: // ---- Control 4: harm channel is ACTIVE and directional ----
  56: // At s_exp=0 (gate=1 everywhere), raising central harm-detection b_H_C from 0 -> 1 should move central toward the
  57: // oracle (it stops overvaluing harmful projects). Expect m(theta)=E[(D-C)/O] to DECREASE (central improves).
  58: {
  59:   const base = { ...baseConfig(), ...SMALL, s_exp: 0 };
  60:   const blind = estimand({ ...base, b_H_C: 0 }, { nWorlds: NW }).m_hat;
  61:   const sighted = estimand({ ...base, b_H_C: 1 }, { nWorlds: NW }).m_hat;
  62:   check('C4 harm channel active (m falls as central sees harm)', sighted < blind - 1e-4, `m(b_H_C=0)=${blind.toFixed(4)} -> m(b_H_C=1)=${sighted.toFixed(4)}`);
  63: }
  64: 
  65: // ---- Baseline descriptive run (not a pass/fail) ----
  66: {
  67:   const cfg = { ...baseConfig(), ...SMALL };
  68:   const r = estimand(cfg, { nWorlds: NW });
  69:   console.log(`\nBaseline (defaults, SMALL world): m_hat=${r.m_hat.toFixed(4)}  CI=[${r.ci[0].toFixed(4)}, ${r.ci[1].toFixed(4)}]  pi_deg=${r.pi_deg.toFixed(3)}  kept=${r.n_kept}/${r.n_worlds}`);
  70: }
  71: 
  72: console.log(`\n${allOk ? 'ALL CONTROLS PASSED' : 'SOME CONTROLS FAILED'}`);
  73: process.exit(allOk ? 0 : 1);
### scripts/simulation/e4-v5/test.mjs
   1: // E4 v1.14 — acceptance fixtures (capability criterion) + embargo self-tests. Run: npm run e4:test
   2: // Proves the pipeline SURFACES a strong distributed win, a strong central win, and a null when each is the ground
   3: // truth — i.e. results are surfaced, not selected-in or washed out. Plus: the closed schema + embargo reject
   4: // forbidden multiplier/ratio notation.
