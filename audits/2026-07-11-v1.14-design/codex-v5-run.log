  39: // ---- Embargo: reject multiplier/ratio notation in rendered text ----
  40: const rejects = (txt) => { try { assertNoEmbargoedTokens(txt); return false; } catch { return true; } };
  41: check('EMBARGO rejects "2.2x"', rejects('gain of 2.2x'));
  42: check('EMBARGO rejects Unicode "2.2×"', rejects('gain of 2.2×'));
  43: check('EMBARGO rejects "D/C"', rejects('ratio D/C = 1.4'));
  44: check('EMBARGO allows clean percent text', !rejects('m̂ is 45.7% of the oracle, parity at 0'));
  45: 
  46: // ---- Closed schema: reject an extra field / missing required ----
  47: check('SCHEMA rejects extra field', validateOutput({ contract_version: 'x', theta_id: 't', pi_deg: 0, m_hat: 0, ci: [0, 0], sign_status: 'pos', materiality_status: 'material', degeneracy_status: 'ok', numerical_status: 'resolved', ratio_D_over_C: 2.2 }).length > 0);
  48: check('SCHEMA accepts a clean output', validateOutput({ contract_version: 'x', theta_id: 't', pi_deg: 0, m_hat: 0.1, ci: [0.05, 0.15], sign_status: 'pos', materiality_status: 'material', degeneracy_status: 'ok', numerical_status: 'resolved' }).length === 0);
  49: 
  50: // ---- Fail-closed config: unknown parameter throws ----
  51: {
