   6: import { estimand } from './engine.mjs';
   7: import { assertNoEmbargoedTokens } from './adapter.mjs';
   8: import { validateOutput } from './schema.mjs';
   9: 
  10: const WORLD = { N: 900, K: 120 };
  11: const NW = 500;
  12: let ok = true;
