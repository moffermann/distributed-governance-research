64:// ---- PROP 2: capture threshold closed form vs the values used in e4-v5
65:console.log("\nPROP 2: capture threshold rho(C) = (k_d*C + p_d*F)/(k_c + p_c*F).  [k_c=.3 p_c=.1 k_d=.3 p_d~1 F=3]");
66:const kc=0.3,pc=0.1,kd=0.3,pd=0.97,F=3;
67:for(const C of [3,5.5,10]){
68:  const lc=(kc+pc*F)/C, ld=kd+pd*F/C, rho=(kd*C+pd*F)/(kc+pc*F);
69:  console.log("   C="+C.toString().padStart(4)+": lambda*_central="+lc.toFixed(2)+"  lambda*_distributed="+ld.toFixed(2)+"  rho="+rho.toFixed(1)+"x");
70:}
71:console.log("   => central threshold ~0.10-0.20 (matches sim's net-harmful onset); distributed ~0.6-1.3;");
72:console.log("      rho rises with C (6.3x -> 9.8x); distributed threshold floored by k_d as C->0.");
73:
74:// ---- PROP 3: detection floor theorem m*q = -ln(1-p)
75:console.log("\nPROP 3: detection floor  m*q = -ln(1-p).  Reproduces the floor table:");
76:for(const [lbl,p] of [["beat central p=0.10",0.10],["p=0.50",0.50],["strong p=0.90",0.90],["near-viral p=0.99",0.99]])
77:  console.log("   "+lbl.padEnd(20)+": m*q = "+(-Math.log(1-p)).toFixed(2));
