24:function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296};}
25:function gauss(rng){let u=0,v=0;while(u===0)u=rng();while(v===0)v=rng();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);}
26:function buildWorld({N,K,seed,mean,sd}){
27:  const rng=mulberry32(seed>>>0); const interested=Array.from({length:K},()=>[]); const cost=new Array(K);
28:  for(let j=0;j<K;j++){ cost[j]=1+9*rng(); const frac=0.1+0.6*rng(); for(let i=0;i<N;i++) if(rng()<frac) interested[j].push(gauss(rng)*sd+mean); }
29:  const Sp=interested.map(l=>l.reduce((a,v)=>a+(v>0?v:0),0));   // sum of positive valuations
30:  const Sm=interested.map(l=>l.reduce((a,v)=>a+(v<0?-v:0),0));  // sum of |negative valuations|
31:  const trueVal=interested.map((l,j)=>Sp[j]-Sm[j]);
32:  return {interested,cost,Sp,Sm,trueVal};
33:}
34:function fund(scores,cost,P){ const o=scores.map((s,j)=>[s/cost[j],j]).sort((a,b)=>b[0]-a[0]).map(x=>x[1]); const ch=[]; let sp=0;
35:  for(const j of o){ if(scores[j]<=0) continue; if(sp+cost[j]<=P){ch.push(j); sp+=cost[j];} } return ch; }
36:const deliver=(ch,tv)=>ch.reduce((a,j)=>a+tv[j],0);
37:
38:const N=3000,K=300,seeds=8;
39:// ---- PROP 1: analytical estimators (NO noise, NO sampling) => parity at beta = 1 - gamma
40:function analyticAdv(gamma,beta){
41:  let c=0,d=0,o=0;
42:  for(let s=0;s<seeds;s++){
43:    const W=buildWorld({N,K,seed:2000+s,mean:0.01,sd:1.5}); const P=W.cost.reduce((a,b)=>a+b,0)/3;
44:    const cen=W.Sp.map((sp,j)=>sp-gamma*W.Sm[j]);        // theta_C = gamma
45:    const dis=W.Sp.map((sp,j)=>sp-(1-beta)*W.Sm[j]);     // theta_D = 1 - beta
46:    o+=deliver(fund(W.trueVal,W.cost,P),W.trueVal);
47:    c+=deliver(fund(cen,W.cost,P),W.trueVal);
48:    d+=deliver(fund(dis,W.cost,P),W.trueVal);
49:  }
50:  return {adv:d/c, cf:c/o, df:d/o};
51:}
52:console.log("E4 ANALYTICAL BACKBONE — closed forms verified against the simulation\n");
53:console.log("PROP 1: parity law beta* = 1 - gamma. Analytical estimators (noise-free, sample-free).");
54:console.log("  advantage distributed/central; parity (~1.00) must fall on the anti-diagonal gamma+beta=1:\n");
55:process.stdout.write("  g\\b  |");
56:const B=[0,0.25,0.5,0.75,1.0]; for(const b of B) process.stdout.write("  b="+b.toFixed(2));
57:console.log("\n  -----+"+"--------".repeat(B.length));
58:for(const g of [0,0.25,0.5,0.75,1.0]){ process.stdout.write("  "+g.toFixed(2)+" |");
59:  for(const b of B){ const r=analyticAdv(g,b); process.stdout.write("   "+(r.adv>=1?" ":"")+r.adv.toFixed(2)); } console.log(""); }
60:console.log("\n  => parity sits exactly where gamma+beta=1 (each anti-diagonal cell ~1.00), confirming beta*=1-gamma.");
61:console.log("     (With sim noise/sampling added, the (1,0) corner dips to ~0.89: the variance tie-breaker,");
62:console.log("      central proxy-noise vs distributed zero revelation-noise — predicted by bias-variance.)");
