   77: for(const b of B) process.stdout.write("  b="+b.toFixed(2));
   78: console.log("\n  ----------+"+"--------".repeat(B.length));
   79: for(const g of G){ process.stdout.write("   g="+g.toFixed(2)+"   |");
   80:   for(const b of B){ const a=medAdv(g,b); process.stdout.write("  "+(a>=1?" ":"")+a.toFixed(2)); }
   81:   console.log(""); }
   82: console.log("\nReading: advantage>1 = distributed delivers more true value; ~1 = parity; <1 = central wins.");
   83: console.log("The distributed edge exists only where the platform's voice bias (beta) is milder than");
