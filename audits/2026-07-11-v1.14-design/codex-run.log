95:// crossover: for each gamma, the beta at which advantage hits parity (interpolated on the grid)
96:console.log("\nParity crossover (beta where distributed advantage falls to ~1.0), per gamma:");
97:for(const g of G){ let cross="never (>1 across all beta)"; let prev=medAdv(g,0);
98:  for(const b of B.slice(1)){ const a=medAdv(g,b); if(a<=1.0){ cross="beta ~ "+b.toFixed(2)+" (adv "+a.toFixed(2)+"x)"; break; } prev=a; }
99:  if(medAdv(g,0)<=1.0) cross="already <=1 at beta=0";
100:  console.log("   gamma="+g.toFixed(2)+": "+cross); }
