92:  console.log("   "+g.toFixed(2)+" "+b.toFixed(2)+" |      "+(100*s.cf).toFixed(0).padStart(4)+"%      |       "+(100*s.df).toFixed(0).padStart(4)+"%        |        "+s.fav+"/"+s.n);
93:}
