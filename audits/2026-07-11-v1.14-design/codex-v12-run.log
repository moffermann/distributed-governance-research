  49: // uniform Monte-Carlo over the anchored envelope: fraction of samples where each arm wins (volume, with SE) + m dist.
  50: function envelopeSweep(nWorlds, n) {
  51:   const base = { ...baseConfig(), ...WORLD };
  52:   const rng = makeRng((SEED ^ 0x5bd1e995) >>> 0);
  53:   const ms = []; let pos = 0, neg = 0, par = 0, resolved = 0;
  54:   const zt = CLASSIFY.zero_tol.value;
  55:   for (let i = 0; i < n; i++) {
  56:     const cfg = { ...base, ...PROBABLE };
  57:     for (const k of SWEPT) cfg[k] = ENV[k][0] + (ENV[k][1] - ENV[k][0]) * rng.u();
  58:     const r = estimand(cfg, { nWorlds, seed: SEED });
  59:     if (!r.enough || !Number.isFinite(r.m_hat)) continue;
  60:     resolved++; ms.push(r.m_hat);
  61:     if (r.m_hat > zt) pos++; else if (r.m_hat < -zt) neg++; else par++;
