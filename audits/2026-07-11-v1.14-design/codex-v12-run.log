FILE: scripts/simulation/e4-v5/frontier.mjs
   1: // E4 v1.14 — ceteris-paribus FRONTIER locators. Hold all knobs at the PROBABLE scenario, sweep ONE axis across its
   2: // physically-possible range, and locate where m = D/O − C/O crosses 0 (the parity frontier). Report the frontier
   3: // location, the probable reference value marked on the axis, and the result at that value. Together with the declared
   4: // combined path, this shows where a measured target configuration would lie relative to the reported frontiers.
   5: // Run: npm run e4:frontier
   6: import { baseConfig, THETA } from './contract.mjs';
   7: import { safeLog } from './adapter.mjs';
   8: import { estimand } from './engine.mjs';
   9: import { PROBABLE, SCENARIO_WORLD as WORLD } from './scenario-configs.mjs';
  10: 
  11: const NW = 400, STEPS = 15;
  12: const pct = (x) => (x >= 0 ? '+' : '') + (100 * x).toFixed(0) + '%';
  13: 
  14: // axes to locate, with a plotting range (clipped from D_F to a legible span) and the plausible value + who-wins-which-way
  15: const AXES = [
  16:   { k: 's_exp',  lo: 0.2, hi: 8,   plaus: PROBABLE.s_exp,  note: 'central harm myopia (higher = blinder on the long tail)' },
  17:   { k: 'b_H_C',  lo: 0.0, hi: 2.0, plaus: PROBABLE.b_H_C,  note: 'central harm detection (higher = less myopic)' },
  18:   { k: 'p',      lo: 0.02, hi: 0.6, plaus: PROBABLE.p,     note: 'citizen participation (higher = denser distributed signal)' },
  19:   { k: 'beta',   lo: 0.0, hi: 0.95, plaus: PROBABLE.beta,  note: 'silencing of opponents (higher = weaker distributed harm-voice)' },
  20:   { k: 'a_V',    lo: 0.2, hi: 3.0, plaus: PROBABLE.a_V,    note: 'visibility tail (higher a_V = flatter tail, more projects visible)' },
  21: ];
  22: 
  23: const base = { ...baseConfig(), ...WORLD, ...PROBABLE };
  24: safeLog('E4 — ceteris-paribus frontiers (others held at the PROBABLE scenario). m = D/O − C/O, parity at 0.\n');
  25: 
  26: for (const ax of AXES) {
  27:   const xs = [], ms = [];
  28:   for (let i = 0; i < STEPS; i++) {
  29:     const x = ax.lo + (ax.hi - ax.lo) * i / (STEPS - 1);
  30:     const m = estimand({ ...base, [ax.k]: x }, { nWorlds: NW }).m_hat;
  31:     xs.push(x); ms.push(m);
  32:   }
  33:   // find the frontier: first adjacent pair whose sign changes; linear-interpolate the crossing
  34:   let frontier = null;
  35:   for (let i = 0; i < STEPS - 1; i++) {
  36:     if (Number.isFinite(ms[i]) && Number.isFinite(ms[i + 1]) && (ms[i] > 0) !== (ms[i + 1] > 0)) {
  37:       frontier = xs[i] + (0 - ms[i]) * (xs[i + 1] - xs[i]) / (ms[i + 1] - ms[i]);
  38:       break;
  39:     }
  40:   }
  41:   const mAtPlaus = estimand({ ...base, [ax.k]: ax.plaus }, { nWorlds: NW }).m_hat;
  42:   safeLog(`■ ${ax.k}  — ${ax.note}`);
  43:   if (frontier === null) {
  44:     const who = ms[Math.floor(STEPS / 2)] > 0 ? 'Core v0 wins across the whole plotted range' : 'central wins across the whole plotted range';
  45:     safeLog(`    frontier: none in [${ax.lo}, ${ax.hi}] — ${who}`);
  46:   } else {
  47:     safeLog(`    frontier (m=0) at ${ax.k} ≈ ${frontier.toFixed(2)}   |   plausible value = ${ax.plaus}  →  m = ${pct(mAtPlaus)} (Core v0 ${mAtPlaus > 0 ? 'wins' : 'loses'} at the reference point)`);
  48:   }
  49:   // compact curve
  50:   safeLog('    m across axis: ' + xs.map((x, i) => `${x.toFixed(2)}:${pct(ms[i])}`).join('  '));
  51:   safeLog('');
  52: }
  53: // ---- combined scenario-path frontier: interpolate PROBABLE -> PRO_CENTRAL (the declared central-favourable endpoint),
  54: // locate m=0. t=0 is the probable scenario; t=1 is the declared central-favourable endpoint (a declared endpoint, not
  55: // beyond-realistic). The crossing t* tells how far toward central-favourable conditions parity is reached. ----
  56: import { PRO_CENTRAL } from './scenario-configs.mjs';
  57: const compKeys = Object.keys(PRO_CENTRAL).filter((k) => PRO_CENTRAL[k] !== PROBABLE[k]);
  58: const clampDF = (k, v) => Math.max(THETA[k].df[0], Math.min(THETA[k].df[1], v));
  59: const lerp = (t) => { const c = { ...base }; for (const k of compKeys) c[k] = clampDF(k, PROBABLE[k] + t * (PRO_CENTRAL[k] - PROBABLE[k])); return c; };
  60: safeLog('■ probable → declared central-favourable endpoint (combined path; t in [0,1] is the declared interpolation segment)');
  61: const ts = [], tms = [];
  62: for (let i = 0; i <= 16; i++) { const t = i / 8; const m = estimand(lerp(t), { nWorlds: NW }).m_hat; ts.push(t); tms.push(m); }
  63: let tf = null;
  64: for (let i = 0; i < ts.length - 1; i++) if ((tms[i] > 0) !== (tms[i + 1] > 0)) { tf = ts[i] + (0 - tms[i]) * (ts[i + 1] - ts[i]) / (tms[i + 1] - tms[i]); break; }
  65: safeLog(`    t=0 probable scenario → t=1 declared central-favourable endpoint`);
  66: safeLog(`    m across t: ` + ts.filter((_, i) => i % 2 === 0).map((t, i) => `t=${t.toFixed(2)}:${pct(tms[i * 2])}`).join('  '));
  67: safeLog(tf === null
  68:   ? `    frontier: none in t∈[0,2] — one endpoint does not cross parity`
  69:   : `    frontier (m=0) at t ≈ ${tf.toFixed(2)}  →  conditions ${tf < 1 ? `~${Math.round(tf * 100)}% of the way from probable to the declared central-favourable endpoint flip the winner to the central (within the declared interpolation segment)` : `must exceed the declared central-favourable endpoint (t>1)`}`);
  70: safeLog('');
  71: safeLog('Read: none of the FIVE plotted one-factor slices flips the winner from the probable scenario over its plotted');
  72: safeLog('range (a limited robustness statement over those five slices, NOT over all parameters). The frontier is reached');
  73: safeLog('on the combined path within the declared interpolation segment. NOTE: t is a linear mix of heterogeneous knobs,');
  74: safeLog('an illustrative path — not a calibrated competence scale.');

