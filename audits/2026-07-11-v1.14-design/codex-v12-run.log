  63:   const share = (c) => (resolved ? c / resolved : NaN);
  64:   const se = (p) => (resolved ? Math.sqrt(Math.max(0, p * (1 - p)) / resolved) : NaN);
  65:   return { resolved, n, distShare: share(pos), centShare: share(neg), parShare: share(par),
  66:     distShareSE: se(share(pos)), p5: pctl(ms, 0.05), p50: pctl(ms, 0.50), p95: pctl(ms, 0.95),
  67:     enough: resolved >= EVIDENCE.n_env * 0.5 };
  68: }
