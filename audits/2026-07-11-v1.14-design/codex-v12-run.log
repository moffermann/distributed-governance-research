 180: // FNV-1a hash of an arbitrary JSON-able manifest (no Date/Math.random).
 181: export function resolvedHash(manifest) {
 182:   const s = JSON.stringify(manifest);
 183:   let h = 0x811c9dc5;
 184:   for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 0x01000193) >>> 0; }
 185:   return 'fnv1a-' + h.toString(16).padStart(8, '0');
 186: }
 187: 
 188: // Base config = registered default values.
 189: export function baseConfig() {
 190:   const cfg = {};
 191:   for (const [k, spec] of Object.entries(THETA)) cfg[k] = spec.value;
 192:   return cfg;
 193: }
 194: 
 195: // Deterministic content hash of the frozen sets (so the joint D_F/R_alpha objects and thresholds are pinned before
 196: // any production run). Simple FNV-1a over a canonical JSON — no Date/Math.random.
 197: export function contractHash() {
 198:   const canonical = JSON.stringify({ v: CONTRACT_VERSION, THETA, NUM, CLASSIFY, ALPHA_LEVELS, AGGREGATION, EVIDENCE });
 199:   let h = 0x811c9dc5;
 200:   for (let i = 0; i < canonical.length; i++) {
 201:     h ^= canonical.charCodeAt(i);
 202:     h = Math.imul(h, 0x01000193) >>> 0;
 203:   }
 204:   return 'fnv1a-' + h.toString(16).padStart(8, '0');
 205: }
