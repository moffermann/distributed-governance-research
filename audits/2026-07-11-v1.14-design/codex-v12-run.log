  16:   const keys = Object.keys(PROBABLE);
  17:   const rng = makeRng((NUM.seed.value ^ 0x2545f491) >>> 0);
  18:   let cen = 0, ok = 0;
  19:   for (let i = 0; i < n; i++) {
  20:     const cfg = { ...base, ...PRO_CENTRAL };
  21:     for (const k of keys) cfg[k] = PRO_CENTRAL[k] + rng.u() * frac * (PROBABLE[k] - PRO_CENTRAL[k]);
  22:     const r = estimand(cfg, { nWorlds, seed: NUM.seed.value });
  23:     if (!r.enough || !Number.isFinite(r.m_hat)) continue;
  24:     ok++; if (r.m_hat < -CLASSIFY.zero_tol.value) cen++;
  25:   }
  26:   return { cenFrac: ok ? cen / ok : NaN, cen, ok };
  27: }
  28: import { renderReport, assertNoEmbargoedTokens } from './adapter.mjs';
  29: import { validateOutput } from './schema.mjs';
  30: 
  31: const SEED = NUM.seed.value;
  32: const SWEPT = Object.keys(PROBABLE);   // the knobs varied by the anchored scenarios
  33: const ENV = Object.fromEntries(SWEPT.map((k) => {
  34:   const vals = [PRO_CENTRAL[k], PROBABLE[k], PRO_DIST[k]].filter((v) => v !== undefined);
  35:   return [k, [Math.min(...vals), Math.max(...vals)]];
  36: }));
  37: 
  38: const MANIFEST = {
  39:   contract_version: CONTRACT_VERSION, contract_hash: contractHash(), world: WORLD, seed: SEED,
  40:   probable_nw: EVIDENCE.probable_nw, sweep_nw: EVIDENCE.sweep_nw, n_env: EVIDENCE.n_env,
  41:   swept: SWEPT, envelope: ENV, fixed: EVIDENCE.fixed,
  42:   o_min_frac: CLASSIFY.o_min_frac.value, delta: CLASSIFY.delta.value, zero_tol: CLASSIFY.zero_tol.value,
  43:   estimand: 'ratio-of-sums Sum(D-C)/Sum(O) over kept worlds; headline = PROBABLE scenario m+-CI; global = uniform MC over the anchored envelope -> sign VOLUME fractions (with SE) + m distribution p5/p50/p95',
  44: };
  45: const THETA_ID = 'e4v7+' + resolvedHash(MANIFEST);
