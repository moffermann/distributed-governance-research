  70: export function classify({ point, dfEnv, ralphaHeadline, pi_deg, enough }) {
  71:   const d = CLASSIFY.delta.value;
  72:   let sign_status;
  73:   if (dfEnv.distShare > 0 && dfEnv.centShare > 0) sign_status = 'indeterminate';
  74:   else if (dfEnv.distShare > 0 && dfEnv.centShare === 0) sign_status = 'pos';
  75:   else if (dfEnv.centShare > 0 && dfEnv.distShare === 0) sign_status = 'neg';
  76:   else sign_status = 'zero-touching';
  77:   const [rl, rh] = ralphaHeadline;
  78:   let materiality_status;
  79:   if (rl > d || rh < -d) materiality_status = 'material';
  80:   else if (rl > -d && rh < d) materiality_status = 'negligible';
  81:   else materiality_status = 'uncertain';
  82:   const degeneracy_status = pi_deg >= 1 ? 'degenerate' : (pi_deg > CLASSIFY.pi_deg_warn.value ? 'high' : 'ok');
  83:   const numerical_status = (enough && dfEnv.enough && (point.ci[1] - point.ci[0]) < d) ? 'resolved' : 'unresolved';
  84:   return { sign_status, materiality_status, degeneracy_status, numerical_status };
  85: }
