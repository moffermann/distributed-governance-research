  87: export function buildEvidence() {
  88:   const base = { ...baseConfig(), ...WORLD };
  89:   if (!inRalpha(base, ['N', 'K'])) throw new Error('[evidence] world N/K outside declared R_alpha');
  90:   const pt = estimand({ ...base, ...PROBABLE }, { nWorlds: EVIDENCE.probable_nw, seed: SEED });   // PROBABLE headline
  91:   if (!pt.enough) throw new Error(`[evidence] probable point insufficient: ${pt.n_kept} kept — aborting fail-closed`);
  92: 
  93:   const env = envelopeSweep(EVIDENCE.sweep_nw, EVIDENCE.n_env);
  94:   if (env.resolved === 0) throw new Error('[evidence] envelope sweep has no resolved samples — aborting fail-closed');
  95:   const centralRegion = centralRegionProbe(EVIDENCE.sweep_nw, 40, 0.2);   // 20%-inward neighbourhood of PRO_CENTRAL
  96: 
  97:   const st = classify({ point: pt, dfEnv: env, ralphaHeadline: pt.ci, pi_deg: pt.pi_deg, enough: pt.enough });
  98:   // the product-box sampler is Core-v0-heavy, but a coordinated central-favourable region exists (targeted probe) —
  99:   // so the GLOBAL sign is region-dependent (indeterminate), not the box sampler's one-sided result.
 100:   if (centralRegion.cenFrac > 0 && env.distShare > 0) st.sign_status = 'indeterminate';
 101:   const out = {
 102:     contract_version: CONTRACT_VERSION, theta_id: THETA_ID, pi_deg: pt.pi_deg,
 103:     m_hat: pt.m_hat, ci: pt.ci,
 104:     df_dist_share: env.distShare, df_cent_share: env.centShare, df_par_share: env.parShare, df_dist_share_se: env.distShareSE,
 105:     ...st,
 106:   };
 107:   const errs = validateOutput(out);
 108:   if (errs.length) throw new Error('[evidence] output invalid: ' + errs.join('; '));
 109:   return { out, env, pt, centralRegion, manifest: MANIFEST };
 110: }
 111: 
 112: function main() {
 113:   const { out, env, pt, centralRegion } = buildEvidence();
 114:   const P = (x) => (x >= 0 ? '+' : '') + (100 * x).toFixed(1) + '%';
 115:   const sh = (x) => (100 * x).toFixed(0) + '%';
 116:   const ruleOf3 = env.centShare === 0 ? (3 / env.resolved) : NaN;   // one-sided 95% upper bound when 0 observed
 117:   const text = [
 118:     `E4 evidence — contract ${out.contract_version} — θ:${out.theta_id}`,
 119:     `  PROBABLE scenario (source-motivated declared reference) headline: m = ${P(out.m_hat)}  95% CI [${P(out.ci[0])}, ${P(out.ci[1])}]   Core v0 ${P(pt.dOverO)} of oracle · central ${P(pt.cOverO)}`,
 120:     `  finite product-box sample of the declared envelope (${env.resolved}/${env.n} draws, knobs independent uniform):`,
 121:     `    m distribution: p5 ${P(env.p5)} · median ${P(env.p50)} · p95 ${P(env.p95)}`,
 122:     `    Core v0 wins ${env.resolved - Math.round(env.centShare * env.resolved) - Math.round(env.parShare * env.resolved)}/${env.resolved} draws · central ${Math.round(env.centShare * env.resolved)} · parity ${Math.round(env.parShare * env.resolved)}` +
 123:       (Number.isFinite(ruleOf3) ? `   (0 central: one-sided 95% upper bound on central-win prob ≈ ${sh(ruleOf3)}, rule of three — NOT zero)` : ''),
 124:     `  targeted probe of the coordinated central-favourable region (20% inward of PRO-CENTRAL): central wins ${centralRegion.cen}/${centralRegion.ok} draws`,
 125:     `    ⇒ a real central-winning region EXISTS off the independent-box sample; the GLOBAL winner is region-dependent, not one-sided`,
 126:     `  status → sign:${out.sign_status} (region-dependent)  materiality:${out.materiality_status}  degeneracy:${out.degeneracy_status}  numerical:${out.numerical_status}`,
 127:     `  π_deg: ${sh(out.pi_deg)}   contract hash: ${MANIFEST.contract_hash}`,
 128:     `  (named scenarios & frontiers: npm run e4:scenarios / e4:frontier — see research/e4-plausible-anchors.md)`,
 129:   ].join('\n');
 130:   assertNoEmbargoedTokens(text);
 131:   console.log(text);
 132: }
 133: if (process.argv[1] && fileURLToPath(import.meta.url) === process.argv[1]) main();
FILE: scripts/simulation/e4-v5/schema.mjs
   1: // E4 v1.14 — minimal closed-schema validator (no external deps). Enforces additionalProperties:false, required
   2: // fields, and enums from the contract's OUTPUT_SCHEMA. The schema deliberately has NO field able to carry D/C or a
   3: // ratio-with-parity-1; this validator guarantees no extra field sneaks one in.
   4: import { OUTPUT_SCHEMA } from './contract.mjs';
   5: 
   6: export function validateOutput(obj) {
   7:   const S = OUTPUT_SCHEMA, errs = [];
   8:   if (typeof obj !== 'object' || obj === null) return ['output is not an object'];
   9:   for (const k of Object.keys(obj)) {
  10:     if (!(k in S.properties)) errs.push(`forbidden extra field: ${k}`); // additionalProperties:false
  11:   }
  12:   for (const k of S.required) if (!(k in obj)) errs.push(`missing required field: ${k}`);
  13:   for (const [k, spec] of Object.entries(S.properties)) {
  14:     if (!(k in obj)) continue;
  15:     const v = obj[k];
  16:     if (spec.enum && !spec.enum.includes(v)) errs.push(`${k}=${JSON.stringify(v)} not in enum ${JSON.stringify(spec.enum)}`);
  17:     if (spec.type === 'number' && typeof v !== 'number') errs.push(`${k} must be number`);
  18:     if (spec.type === 'string' && typeof v !== 'string') errs.push(`${k} must be string`);
  19:     if (spec.type === 'array') {
  20:       if (!Array.isArray(v)) errs.push(`${k} must be array`);
  21:       else if (spec.minItems && v.length < spec.minItems) errs.push(`${k} too short`);
  22:       else if (spec.maxItems && v.length > spec.maxItems) errs.push(`${k} too long`);
  23:     }
  24:     if (spec.minimum !== undefined && v < spec.minimum) errs.push(`${k} below minimum`);
  25:     if (spec.maximum !== undefined && v > spec.maximum) errs.push(`${k} above maximum`);
  26:     // recursive finiteness: no NaN/Infinity may serialize
  27:     if (spec.type === 'number' && !Number.isFinite(v)) errs.push(`${k} must be finite (got ${v})`);
  28:     if (spec.type === 'array') for (const el of (Array.isArray(v) ? v : [])) if (!Number.isFinite(el)) errs.push(`${k} has non-finite element`);
  29:   }
  30:   // m_Ralpha nested object: each entry must be a [finite, finite] interval with lo<=hi
  31:   if (obj.m_Ralpha && typeof obj.m_Ralpha === 'object') {
  32:     for (const [al, iv] of Object.entries(obj.m_Ralpha)) {
  33:       if (!Array.isArray(iv) || iv.length !== 2 || !iv.every(Number.isFinite)) errs.push(`m_Ralpha[${al}] must be [finite,finite]`);
  34:       else if (iv[0] > iv[1]) errs.push(`m_Ralpha[${al}] inverted`);
  35:     }
  36:   }
  37:   return errs;
  38: }
FILE: scripts/simulation/e4-v5/atlas.mjs
   1: // E4 v1.14 — parity ATLAS (visualization only; does not touch the model). Sweeps TWO axes and reports m(theta)
   2: // at each cell, holding all other parameters at their registered defaults. This is an explicit 2-axis SLICE
   3: // (honest by construction — it does not claim to be the full 30-parameter joint set). Output:
   4: //   (1) an accessible numeric grid + ASCII heat map to the console (primary, screen-reader friendly), and
   5: //   (2) a JSON grid written to atlas-data.json for a color heatmap artifact.
   6: // Run: node scripts/simulation/e4-v5/atlas.mjs
   7: import { writeFileSync } from 'node:fs';
   8: import { baseConfig, THETA } from './contract.mjs';
   9: import { estimand } from './engine.mjs';
  10: 
  11: const WORLD = { N: 1200, K: 130 };
  12: const NW = 250;
  13: const STEPS = 11;
  14: 
  15: // Two axes chosen to CROSS the parity frontier (so both colors appear), reflecting the thesis:
  16: //   X = p      (citizen participation / distributed data density: low => distributed noisy & sparse => central wins)
  17: //   Y = s_exp  (central harm myopia: 0 => central sees harm everywhere; high => blind on the long tail => distributed wins)
  18: // All other parameters held at their registered defaults (b_H_C=0.5, beta=0.4, ...). Honest 2-axis slice.
  19: const AX = { key: 'p',     from: 0.02, to: 0.6, label: 'p  citizen participation (→ denser distributed evidence)' };
  20: const AY = { key: 's_exp', from: 0.0,  to: 6.0, label: 's_exp  central harm myopia (→ central blind on the long tail)' };
  21: const HOLD = {};
  22: 
  23: const lin = (a, b, n, i) => a + (b - a) * (i / (n - 1));
  24: const grid = [];       // grid[iy][ix] = m
  25: const xs = [], ys = [];
  26: for (let i = 0; i < STEPS; i++) { xs.push(lin(AX.from, AX.to, STEPS, i)); ys.push(lin(AY.from, AY.to, STEPS, i)); }
  27: 
  28: for (let iy = STEPS - 1; iy >= 0; iy--) {          // top row = highest Y
  29:   const row = [];
  30:   for (let ix = 0; ix < STEPS; ix++) {
  31:     const cfg = { ...baseConfig(), ...WORLD, ...HOLD, [AX.key]: xs[ix], [AY.key]: ys[iy] };
  32:     row.push(estimand(cfg, { nWorlds: NW }).m_hat);
  33:   }
  34:   grid.push(row);
  35: }
  36: 
  37: // ---- ASCII heat map (accessible) ----
  38: // glyph by sign & magnitude: distributed wins (+) as D/d, central wins (-) as C/c, parity as ·
  39: const glyph = (m) => {
  40:   if (m > 0.20) return 'D'; if (m > 0.05) return 'd';
  41:   if (m < -0.20) return 'C'; if (m < -0.05) return 'c';
  42:   return '·';
  43: };
  44: console.log('E4 parity atlas — m(θ) = (D − C)/O, signed fraction of the full-information oracle (parity at 0)');
  45: console.log(`  X → ${AX.label}`);
  46: console.log(`  Y ↑ ${AY.label}`);
  47: console.log('  glyph: D=distributed wins strongly, d=mildly, ·=parity, c=central mildly, C=central strongly\n');
  48: console.log('        ' + xs.map((x) => x.toFixed(2).padStart(6)).join(''));
  49: for (let r = 0; r < STEPS; r++) {
  50:   const yval = ys[STEPS - 1 - r].toFixed(2).padStart(5);
  51:   const glyphs = grid[r].map((m) => glyph(m).padStart(6)).join('');
  52:   console.log(`  ${yval} ${glyphs}`);
  53: }
  54: console.log('\n  numeric grid (%, top row = highest ' + AY.key + '):');
  55: console.log('        ' + xs.map((x) => x.toFixed(2).padStart(7)).join(''));
  56: for (let r = 0; r < STEPS; r++) {
  57:   const yval = ys[STEPS - 1 - r].toFixed(2).padStart(5);
  58:   console.log(`  ${yval} ` + grid[r].map((m) => (100 * m).toFixed(0).padStart(7)).join(''));
  59: }
  60: 
  61: // region shares
  62: let win = 0, lose = 0, par = 0;
  63: for (const row of grid) for (const m of row) { if (m > 0.05) win++; else if (m < -0.05) lose++; else par++; }
  64: const tot = STEPS * STEPS;
  65: console.log(`\n  region shares over this slice: distributed-wins ${(100*win/tot).toFixed(0)}% · parity ${(100*par/tot).toFixed(0)}% · central-wins ${(100*lose/tot).toFixed(0)}%`);
  66: 
  67: writeFileSync(new URL('./atlas-data.json', import.meta.url), JSON.stringify({
  68:   xKey: AX.key, yKey: AY.key, xLabel: AX.label, yLabel: AY.label, hold: HOLD, world: WORLD, nWorlds: NW,
  69:   xs, ys: [...ys], grid, note: 'grid[0] = highest Y row; m = (D-C)/O signed fraction of oracle',
  70: }, null, 2));
  71: console.log('\n  wrote atlas-data.json');
