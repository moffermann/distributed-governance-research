 163:   // world-cluster bootstrap CI (inner simulation variability only): resample worlds, recompute the ratio of sums.
 164:   const B = NUM.bootstrap_reps.value;
 165:   const bootRng = makeRng((seed ^ 0x9e3779b9) >>> 0);
 166:   const boots = [];
 167:   if (kept.length) {
 168:     for (let bI = 0; bI < B; bI++) {
 169:       let bn = 0, bd = 0;
 170:       for (let t = 0; t < kept.length; t++) { const w = kept[Math.floor(bootRng.u() * kept.length)]; bn += (w.D - w.C); bd += w.O; }
 171:       if (bd > 0) boots.push(bn / bd);
 172:     }
 173:     boots.sort((a, b) => a - b);
 174:   }
 175:   const lo = boots.length ? boots[Math.floor((1 - NUM.ci_level.value) / 2 * boots.length)] : NaN;
 176:   const hi = boots.length ? boots[Math.floor((1 + NUM.ci_level.value) / 2 * boots.length) - 1] : NaN;
 177: 
 178:   const sumD = kept.reduce((s, x) => s + x.D, 0), sumC = kept.reduce((s, x) => s + x.C, 0);
 179:   const dOverO = den > 0 ? sumD / den : NaN, cOverO = den > 0 ? sumC / den : NaN;  // efficiency of each arm vs oracle
 180:   const enough = kept.length >= Math.max(NUM.min_kept_floor.value, NUM.min_kept_frac.value * worlds.length);
 181:   return { m_hat, ci: [lo, hi], pi_deg, n_kept: kept.length, n_worlds: worlds.length, o_min, enough, dOverO, cOverO };
