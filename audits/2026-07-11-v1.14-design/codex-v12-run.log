  69:       if (rng.u() < reportProb) sumReport += (u + cfg.sigma_e * rng.normal()) / cfg.p;
  70:     }
  71:     const Splus = sumPos / n;                                   // support (mean of positive parts)
  72:     const H = sumNeg / n;                                       // harm (mean opposition intensity)
  73:     const S = Splus - H;                                        // true net value (mean scale)
  74:     const M_D = sumReport / n;                                  // behavioral coverage estimator; E[M_D|u]=S+ -(1-beta)H
  75: 
  76:     const v_pj = cfg.v_p0 + cfg.gamma * g + cfg.sigma_v * rng.normal();
  77:     const sV = Math.pow(Math.max(0, Math.min(1, V)), cfg.s_exp);// harm gate: ~0 on long tail, ~1 when salient
  78:     const M_C = cfg.a + cfg.b * Splus + cfg.w * (v_pj - Splus) - cfg.b_H_C * sV * H + cfg.sigma_C * rng.normal();
  79: 
  80:     const P = V;                                               // visible salience -> credit (linear scale would cancel under z)
  81:     projects.push({ S, c, M_C, M_D, P });
