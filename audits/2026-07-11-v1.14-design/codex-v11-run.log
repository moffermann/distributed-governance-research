  95: check('EMBARGO rejects "double"', rejects('double the delivered value'));
  96: check('EMBARGO rejects lowercase "d/c"', rejects('the d/c ratio'));
  97: check('EMBARGO rejects zero-width-split "2.2​x"', rejects('gain of 2.2​x'));
  98: check('EMBARGO rejects "fourfold"', rejects('a fourfold increase'));
  99: check('EMBARGO rejects "two times"', rejects('two times more value'));
 100: check('EMBARGO rejects HTML "&times;"', rejects('gain of 2.2&times;'));
 101: check('EMBARGO rejects word-joiner-split "2.2⁠x"', rejects('gain of 2.2⁠x'));
 102: check('EMBARGO rejects "D/C"', rejects('ratio D/C = 1.4'));
