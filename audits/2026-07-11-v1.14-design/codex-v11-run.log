  81:     mc < -0.05 && mn > 0 && mn < mo && mo < mp && mp > 0.30 && md > mp,
  82:     `PRO_CENTRAL=${mc.toFixed(2)} NO_MYOPIA=${mn.toFixed(2)} MYOPIA_OFF=${mo.toFixed(2)} PROBABLE=${mp.toFixed(2)} PRO_DIST=${md.toFixed(2)}`);
