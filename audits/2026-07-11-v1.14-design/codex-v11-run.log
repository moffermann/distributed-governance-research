  22:   check('FIX strong-distributed => m materially > 0', val > 0.10, `m=${val.toFixed(3)}`);
  23: }
  24: // STRONG CENTRAL: central competent (gate=1, sees harm, low noise, no credit tilt), distributed crippled
  25: // (opponents silenced, low participation, noisy) => central wins.
  26: {
  27:   const val = m({ s_exp: 0, b_H_C: 1, a: 0, w: 0, b: 1, sigma_C: 0.05, lambda: 0, beta: 0.9, p: 0.05, sigma_e: 1.5 });
  28:   check('FIX strong-central => m < 0 (central wins)', val < -0.03, `m=${val.toFixed(3)}`);
  29: }
  30: // NULL: both arms near the oracle => negligible gap.
  31: {
  32:   const val = m({ s_exp: 0, b_H_C: 1, a: 0, w: 0, b: 1, sigma_C: 0.02, lambda: 0, beta: 0, p: 1, sigma_e: 0 });
  33:   check('FIX null => |m| negligible', Math.abs(val) < 0.03, `m=${val.toFixed(4)}`);
