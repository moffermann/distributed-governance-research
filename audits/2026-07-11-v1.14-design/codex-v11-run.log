 131: // ---------------- estimand m(theta) = E[(D-C)/O | O>o_min], plus pi_deg ----------------
 132: function median(arr) {
 133:   if (arr.length === 0) return 0;
 134:   const a = [...arr].sort((x, y) => x - y);
 135:   const mid = a.length >> 1;
 136:   return a.length % 2 ? a[mid] : 0.5 * (a[mid - 1] + a[mid]);
 137: }
 138: 
 139: export function estimand(cfg, { nWorlds = NUM.n_worlds.value, seed = NUM.seed.value, oMinAbs = null } = {}) {
 140:   validateConfig(cfg);
 141:   validateDomain(cfg);
 142:   const rng = makeRng(seed);
 143:   const worlds = [];
 144:   for (let wI = 0; wI < nWorlds; wI++) {
 145:     const { D, C, O, empty } = runWorld(cfg, rng);
 146:     if (!empty) worlds.push({ D, C, O });
 147:   }
 148:   const Os = worlds.map((x) => x.O);
 149:   // o_min is an ABSOLUTE floor (default from this config's own median). Passing oMinAbs pins ONE floor across a
 150:   // whole sweep, so degenerate corners (tiny O => exploding (D-C)/O) get most worlds excluded and flagged, rather
 151:   // than injecting divergent ratios into the envelope (Codex: denominator-weighting divergence).
 152:   const o_min = oMinAbs !== null ? oMinAbs : CLASSIFY.o_min_frac.value * median(Os);
 153:   const kept = worlds.filter((x) => x.O > o_min);
 154:   const degCount = worlds.length - kept.length;
 155:   const pi_deg = worlds.length ? degCount / worlds.length : 1;
 156:   // RATIO OF SUMS (robust): m = Σ(D−C)/ΣO over retained worlds. Bounded and stable — a single tiny-O world cannot
 157:   // dominate (as it would in the per-world-ratio mean, Codex's (1,1)/(−1,100) divergence). Interpretation: total
 158:   // true value the arm delivers, as a fraction of the total full-information achievable value.
 159:   const num = kept.reduce((s, x) => s + (x.D - x.C), 0);
 160:   const den = kept.reduce((s, x) => s + x.O, 0);
 161:   const m_hat = den > 0 ? num / den : NaN;
 162: 
 163:   // world-cluster bootstrap CI (inner simulation variability only): resample worlds, recompute the ratio of sums.
 164:   const B = NUM.bootstrap_reps.value;
 165:   const bootRng = makeRng((seed ^ 0x9e3779b9) >>> 0);
 166:   const boots = [];
 167:   if (kept.length) {
 168:     for (let bI = 0; bI < B; bI++) {
 169:       let bn = 0, bd = 0;
 170:       for (let t = 0; t < kept.length; t++) { const w = kept[Math.floor(bootRng.u() * kept.length)]; bn += (w.D - w.C); bd += w.O; }
 171:       if (bd > 0) boots.push(bn / bd);
 172:     }
 173:     boots.sort((a, b) => a - b);
 174:   }
 175:   const lo = boots.length ? boots[Math.floor((1 - NUM.ci_level.value) / 2 * boots.length)] : NaN;
 176:   const hi = boots.length ? boots[Math.floor((1 + NUM.ci_level.value) / 2 * boots.length) - 1] : NaN;
 177: 
 178:   const sumD = kept.reduce((s, x) => s + x.D, 0), sumC = kept.reduce((s, x) => s + x.C, 0);
 179:   const dOverO = den > 0 ? sumD / den : NaN, cOverO = den > 0 ? sumC / den : NaN;  // efficiency of each arm vs oracle
 180:   const enough = kept.length >= Math.max(NUM.min_kept_floor.value, NUM.min_kept_frac.value * worlds.length);
 181:   return { m_hat, ci: [lo, hi], pi_deg, n_kept: kept.length, n_worlds: worlds.length, o_min, enough, dOverO, cOverO };
 182: }

