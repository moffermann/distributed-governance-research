===== scripts/simulation/e4-v5/theorem-check.mjs =====
   1: // E4 v1.14 — regression test for the analytic BENCHMARK (joint-normal fixed-threshold selection lemma).
   2: // Lemma: for (S, X) jointly normal and top-fraction-q selection by X at population threshold t = μ_X + σ_X·z_q,
   3: //   V := E[S·1{X>t}] = q·μ_S + φ(z_q)·Cov(S,X)/sd(X).
   4: // Parity of two selectors X_C, X_D ⇔ Cov(S,X_D)/sd(X_D) = Cov(S,X_C)/sd(X_C).
   5: // This checks the analytic identity that underpins the numerical frontier (the full engine adds eligibility, costs,
   6: // credit — the theorem is the limiting case). Run: node scripts/simulation/e4-v5/theorem-check.mjs
   7: import { makeRng } from './engine.mjs';
   8: 
   9: const PHI = (z) => Math.exp(-0.5 * z * z) / Math.sqrt(2 * Math.PI);
  10: // inverse normal CDF (Acklam) for z_q = Phi^{-1}(1-q)
  11: function invNorm(p) {
  12:   const a = [-3.969683028665376e+01, 2.209460984245205e+02, -2.759285104469687e+02, 1.383577518672690e+02, -3.066479806614716e+01, 2.506628277459239e+00];
  13:   const b = [-5.447609879822406e+01, 1.615858368580409e+02, -1.556989798598866e+02, 6.680131188771972e+01, -1.328068155288572e+01];
  14:   const c = [-7.784894002430293e-03, -3.223964580411365e-01, -2.400758277161838e+00, -2.549732539343734e+00, 4.374664141464968e+00, 2.938163982698783e+00];
  15:   const d = [7.784695709041462e-03, 3.224671290700398e-01, 2.445134137142996e+00, 3.754408661907416e+00];
  16:   const pl = 0.02425, ph = 1 - pl; let q, r;
  17:   if (p < pl) { q = Math.sqrt(-2 * Math.log(p)); return (((((c[0] * q + c[1]) * q + c[2]) * q + c[3]) * q + c[4]) * q + c[5]) / ((((d[0] * q + d[1]) * q + d[2]) * q + d[3]) * q + 1); }
  18:   if (p <= ph) { q = p - 0.5; r = q * q; return (((((a[0] * r + a[1]) * r + a[2]) * r + a[3]) * r + a[4]) * r + a[5]) * q / (((((b[0] * r + b[1]) * r + b[2]) * r + b[3]) * r + b[4]) * r + 1); }
  19:   q = Math.sqrt(-2 * Math.log(1 - p)); return -(((((c[0] * q + c[1]) * q + c[2]) * q + c[3]) * q + c[4]) * q + c[5]) / ((((d[0] * q + d[1]) * q + d[2]) * q + d[3]) * q + 1);
  20: }
  21: 
  22: const rng = makeRng(4242);
  23: const N = 400000, q = 0.3;
  24: const muS = 1.2, sigS = 1.0;
  25: // X = alpha + b*S + noise  => Cov(S,X)=b*sigS^2, Var(X)=b^2 sigS^2 + sigN^2
  26: const alpha = 0.5, b = 0.8, sigN = 0.6;
  27: const S = new Float64Array(N), X = new Float64Array(N);
  28: for (let i = 0; i < N; i++) { const s = muS + sigS * rng.normal(); S[i] = s; X[i] = alpha + b * s + sigN * rng.normal(); }
  29: 
  30: const covSX = b * sigS * sigS, sdX = Math.sqrt(b * b * sigS * sigS + sigN * sigN);
  31: const muX = alpha + b * muS;
  32: const zq = invNorm(1 - q), t = muX + sdX * zq;
  33: const analyticV = q * muS + PHI(zq) * covSX / sdX;
  34: 
  35: // empirical V = mean over ALL candidates of S*1{X>t}
  36: let sumSel = 0, nSel = 0;
  37: for (let i = 0; i < N; i++) if (X[i] > t) { sumSel += S[i]; nSel++; }
  38: const empiricalV = sumSel / N;
  39: 
  40: // Monte-Carlo SE of empirical V
  41: let v2 = 0; for (let i = 0; i < N; i++) { const g = X[i] > t ? S[i] : 0; v2 += (g - empiricalV) * (g - empiricalV); }
  42: const se = Math.sqrt(v2 / N / N);
  43: const zscore = Math.abs(empiricalV - analyticV) / se;
  44: 
  45: console.log('E4 analytic benchmark — joint-normal fixed-threshold lemma');
  46: console.log(`  Cov(S,X)/sd(X) = ${(covSX / sdX).toFixed(4)}   z_q=${zq.toFixed(3)}   selected share=${(nSel / N).toFixed(3)} (target q=${q})`);
  47: console.log(`  analytic  V = ${analyticV.toFixed(5)}`);
  48: console.log(`  empirical V = ${empiricalV.toFixed(5)}  (MC SE=${se.toFixed(5)})`);
  49: console.log(`  |Δ| = ${Math.abs(empiricalV - analyticV).toFixed(5)}  = ${zscore.toFixed(2)} SE`);
  50: 
  51: const ok = zscore < 3;
  52: console.log(`\n${ok ? 'PASS' : 'FAIL'}  analytic identity matches simulation within 3 MC SE`);
  53: process.exit(ok ? 0 : 1);
===== scripts/simulation/e4-v5/schema.mjs =====
   1: // E4 v1.14 — minimal closed-schema validator (no external deps). Enforces additionalProperties:false, required
   2: // fields, and enums from the contract's OUTPUT_SCHEMA. The schema deliberately has NO field able to carry D/C or a
   3: // ratio-with-parity-1; this validator guarantees no extra field sneaks one in.
   4: import { OUTPUT_SCHEMA } from './contract.mjs';
   5: 
   6: export function validateOutput(obj) {
   7:   const S = OUTPUT_SCHEMA, errs = [];
   8:   if (typeof obj !== 'object' || obj === null) return ['output is not an object'];
   9:   for (const k of Object.keys(obj)) {
  10:     if (!(k in S.properties)) errs.push(`forbidden extra field: ${k}`); // additionalProperties:false
  11:   }
  12:   for (const k of S.required) if (!(k in obj)) errs.push(`missing required field: ${k}`);
  13:   for (const [k, spec] of Object.entries(S.properties)) {
  14:     if (!(k in obj)) continue;
  15:     const v = obj[k];
  16:     if (spec.enum && !spec.enum.includes(v)) errs.push(`${k}=${JSON.stringify(v)} not in enum ${JSON.stringify(spec.enum)}`);
  17:     if (spec.type === 'number' && typeof v !== 'number') errs.push(`${k} must be number`);
  18:     if (spec.type === 'string' && typeof v !== 'string') errs.push(`${k} must be string`);
  19:     if (spec.type === 'array') {
  20:       if (!Array.isArray(v)) errs.push(`${k} must be array`);
  21:       else if (spec.minItems && v.length < spec.minItems) errs.push(`${k} too short`);
  22:       else if (spec.maxItems && v.length > spec.maxItems) errs.push(`${k} too long`);
  23:     }
  24:     if (spec.minimum !== undefined && v < spec.minimum) errs.push(`${k} below minimum`);
  25:     if (spec.maximum !== undefined && v > spec.maximum) errs.push(`${k} above maximum`);
  26:     // recursive finiteness: no NaN/Infinity may serialize
  27:     if (spec.type === 'number' && !Number.isFinite(v)) errs.push(`${k} must be finite (got ${v})`);
  28:     if (spec.type === 'array') for (const el of (Array.isArray(v) ? v : [])) if (!Number.isFinite(el)) errs.push(`${k} has non-finite element`);
  29:   }
  30:   // m_Ralpha nested object: each entry must be a [finite, finite] interval with lo<=hi
  31:   if (obj.m_Ralpha && typeof obj.m_Ralpha === 'object') {
  32:     for (const [al, iv] of Object.entries(obj.m_Ralpha)) {
  33:       if (!Array.isArray(iv) || iv.length !== 2 || !iv.every(Number.isFinite)) errs.push(`m_Ralpha[${al}] must be [finite,finite]`);
  34:       else if (iv[0] > iv[1]) errs.push(`m_Ralpha[${al}] inverted`);
  35:     }
  36:   }
  37:   return errs;
  38: }
===== scripts/simulation/e4-v5/controls.mjs =====
   1: // E4 v1.14 — negative controls. These MUST pass or the model is not trustworthy (DESIGN_SKETCH_v5 §5).
   2: // Run: node scripts/simulation/e4-v5/controls.mjs
   3: import { baseConfig } from './contract.mjs';
   4: import { makeRng, runWorld, estimand } from './engine.mjs';
   5: 
   6: const SMALL = { N: 900, K: 120 };            // smaller world for fast, still-meaningful controls (both within D_M)
   7: const NW = 300, SEED = 20260711;
   8: 
   9: // run NW worlds, return per-world {D,C,O} arrays (common random numbers => aligned across configs)
  10: function runWorlds(cfg) {
  11:   const rng = makeRng(SEED);
  12:   const out = [];
  13:   for (let i = 0; i < NW; i++) { const r = runWorld(cfg, rng); if (!r.empty) out.push(r); }
  14:   return out;
  15: }
  16: const maxAbsDiff = (a, b, key) => Math.max(...a.map((x, i) => Math.abs(x[key] - b[i][key])));
  17: const pass = (name, ok, detail) => console.log(`${ok ? 'PASS' : 'FAIL'}  ${name}${detail ? '  — ' + detail : ''}`);
  18: 
  19: let allOk = true;
  20: const check = (name, ok, detail) => { pass(name, ok, detail); allOk = allOk && ok; };
  21: 
  22: // ---- Control 1: signal recovery + exact joint symmetry ----
  23: // a=w=0, b=1, sigma_C=0, b_H_C=1, s_exp=0 (gate=1 everywhere) => M_C = S+ - H = S.
  24: // p=1, beta=0, sigma_e=0 => everyone reports truthfully => M_D = S. All three arms == oracle => D=C=O => m=0.
  25: {
  26:   const cfg = { ...baseConfig(), ...SMALL,
  27:     a: 0, w: 0, b: 1, sigma_C: 0, b_H_C: 1, s_exp: 0, lambda: 0,
  28:     p: 1, beta: 0, sigma_e: 0 };
  29:   const worlds = runWorlds(cfg);
  30:   const maxDC = Math.max(...worlds.map((x) => Math.abs(x.D - x.C)));
  31:   const maxDO = Math.max(...worlds.map((x) => Math.abs(x.D - x.O)));
  32:   const { m_hat } = estimand(cfg, { nWorlds: NW });
  33:   check('C1 signal recovery: M_C=M_D=S => D=C=O', maxDC < 1e-9 && maxDO < 1e-9, `max|D-C|=${maxDC.toExponential(2)}, max|D-O|=${maxDO.toExponential(2)}`);
