===== scripts/simulation/e4-v5/scenarios.mjs =====
   1: // E4 v1.14 — FOUR declared scenarios + ONE diagnostic contrast (research/e4-plausible-anchors.md; values in
   2: // scenario-configs.mjs). Each is a full config; we report m ± 95% CI. PRO-CENTRAL = declared central-favourable
   3: // endpoint (central wins). NO-MYOPIA (bundle) = continuity anchor to the ~0.025 gate. MYOPIA-OFF = diagnostic
   4: // harm-only contrast. PROBABLE = source-motivated reference. PRO-DISTRIBUTED = distributed-favourable.
   5: import { baseConfig } from './contract.mjs';
   6: import { safeLog } from './adapter.mjs';
   7: import { estimand } from './engine.mjs';
   8: import { PRO_CENTRAL, NO_MYOPIA, MYOPIA_OFF, PROBABLE, PRO_DIST, SCENARIO_WORLD as WORLD } from './scenario-configs.mjs';
   9: 
  10: const NW = 800;
  11: const pct = (x) => (x >= 0 ? '+' : '') + (100 * x).toFixed(1) + '%';
  12: function run(name, over) {
  13:   const r = estimand({ ...baseConfig(), ...WORLD, ...over }, { nWorlds: NW });
  14:   safeLog(`${name.padEnd(16)} m = ${pct(r.m_hat).padStart(8)}  95% CI [${pct(r.ci[0])}, ${pct(r.ci[1])}]   Core v0 delivers ${pct(r.dOverO)} of oracle · central ${pct(r.cOverO)}`);
  15:   return r;
  16: }
  17: 
  18: safeLog('E4 — anchored scenarios (m = D/O − C/O, signed fraction of full-information oracle, parity at 0)\n');
  19: run('PRO-CENTRAL', PRO_CENTRAL);      // central's FULL best plausible case — central WINS
  20: run('PROBABLE', PROBABLE);           // source-motivated declared reference
  21: run('MYOPIA-OFF', MYOPIA_OFF);       // GENUINE myopia-only contrast (only s_exp,b_H_C change) — attributes the harm channel ALONE
  22: run('NO-MYOPIA', NO_MYOPIA);         // harm-aware AND competent bundle — continuity anchor to the ~0.025 gate
  23: run('PRO-DISTRIBUTED', PRO_DIST);
  24: safeLog('\nPRO-CENTRAL = a declared central-favourable endpoint (every knob central-favourable) → the central wins.');
  25: safeLog('Sequential attribution (path-dependent, nonlinear model): harm-myopia ALONE (MYOPIA-OFF, only s_exp,b_H_C)');
  26: safeLog('reduces the probable gap +46.6% → +30.4%, i.e. 16.2 of the 40.5-pt decline to +6.1% (~40%); the further step to');
  27: safeLog('the NO-MYOPIA bundle (unbiased/precise/no-credit) reduces it 24.3 pts (~60%). Read C/O < 0 as the central destroying value.');
===== scripts/simulation/e4-v5/frontier.mjs =====
   1: // E4 v1.14 — ceteris-paribus FRONTIER locators. Hold all knobs at the PROBABLE scenario, sweep ONE axis across its
   2: // physically-possible range, and locate where m = D/O − C/O crosses 0 (the parity frontier). Report the frontier
   3: // location, the plausible (R_alpha) value marked on the axis, and which side of the frontier the plausible value
   4: // falls on. Answers "where is the frontier, and does reality sit on the Core-v0 side?". Run: npm run e4:frontier
   5: import { baseConfig, THETA } from './contract.mjs';
   6: import { safeLog } from './adapter.mjs';
   7: import { estimand } from './engine.mjs';
   8: import { PROBABLE, SCENARIO_WORLD as WORLD } from './scenario-configs.mjs';
   9: 
  10: const NW = 400, STEPS = 15;
  11: const pct = (x) => (x >= 0 ? '+' : '') + (100 * x).toFixed(0) + '%';
  12: 
  13: // axes to locate, with a plotting range (clipped from D_F to a legible span) and the plausible value + who-wins-which-way
  14: const AXES = [
  15:   { k: 's_exp',  lo: 0.2, hi: 8,   plaus: PROBABLE.s_exp,  note: 'central harm myopia (higher = blinder on the long tail)' },
  16:   { k: 'b_H_C',  lo: 0.0, hi: 2.0, plaus: PROBABLE.b_H_C,  note: 'central harm detection (higher = less myopic)' },
  17:   { k: 'p',      lo: 0.02, hi: 0.6, plaus: PROBABLE.p,     note: 'citizen participation (higher = denser distributed signal)' },
  18:   { k: 'beta',   lo: 0.0, hi: 0.95, plaus: PROBABLE.beta,  note: 'silencing of opponents (higher = weaker distributed harm-voice)' },
  19:   { k: 'a_V',    lo: 0.2, hi: 3.0, plaus: PROBABLE.a_V,    note: 'visibility tail (higher a_V = flatter tail, more projects visible)' },
  20: ];
  21: 
  22: const base = { ...baseConfig(), ...WORLD, ...PROBABLE };
  23: safeLog('E4 — ceteris-paribus frontiers (others held at the PROBABLE scenario). m = D/O − C/O, parity at 0.\n');
  24: 
  25: for (const ax of AXES) {
  26:   const xs = [], ms = [];
  27:   for (let i = 0; i < STEPS; i++) {
  28:     const x = ax.lo + (ax.hi - ax.lo) * i / (STEPS - 1);
  29:     const m = estimand({ ...base, [ax.k]: x }, { nWorlds: NW }).m_hat;
  30:     xs.push(x); ms.push(m);
  31:   }
  32:   // find the frontier: first adjacent pair whose sign changes; linear-interpolate the crossing
  33:   let frontier = null;
  34:   for (let i = 0; i < STEPS - 1; i++) {
  35:     if (Number.isFinite(ms[i]) && Number.isFinite(ms[i + 1]) && (ms[i] > 0) !== (ms[i + 1] > 0)) {
  36:       frontier = xs[i] + (0 - ms[i]) * (xs[i + 1] - xs[i]) / (ms[i + 1] - ms[i]);
  37:       break;
  38:     }
  39:   }
  40:   const mAtPlaus = estimand({ ...base, [ax.k]: ax.plaus }, { nWorlds: NW }).m_hat;
  41:   safeLog(`■ ${ax.k}  — ${ax.note}`);
  42:   if (frontier === null) {
  43:     const who = ms[Math.floor(STEPS / 2)] > 0 ? 'Core v0 wins across the whole plotted range' : 'central wins across the whole plotted range';
  44:     safeLog(`    frontier: none in [${ax.lo}, ${ax.hi}] — ${who}`);
  45:   } else {
  46:     safeLog(`    frontier (m=0) at ${ax.k} ≈ ${frontier.toFixed(2)}   |   plausible value = ${ax.plaus}  →  m = ${pct(mAtPlaus)} (Core v0 ${mAtPlaus > 0 ? 'wins' : 'loses'} at the plausible point)`);
  47:   }
  48:   // compact curve
  49:   safeLog('    m across axis: ' + xs.map((x, i) => `${x.toFixed(2)}:${pct(ms[i])}`).join('  '));
  50:   safeLog('');
  51: }
  52: // ---- combined scenario-path frontier: interpolate PROBABLE -> PRO_CENTRAL (the central's FULL best plausible case),
  53: // locate m=0. t=0 is the probable scenario; t=1 is the central's full best plausible case (a PLAUSIBLE point, not
  54: // beyond-realistic). The crossing t* tells how far toward central-favourable conditions parity is reached. ----
  55: import { PRO_CENTRAL } from './scenario-configs.mjs';
  56: const compKeys = Object.keys(PRO_CENTRAL).filter((k) => PRO_CENTRAL[k] !== PROBABLE[k]);
  57: const clampDF = (k, v) => Math.max(THETA[k].df[0], Math.min(THETA[k].df[1], v));
  58: const lerp = (t) => { const c = { ...base }; for (const k of compKeys) c[k] = clampDF(k, PROBABLE[k] + t * (PRO_CENTRAL[k] - PROBABLE[k])); return c; };
  59: safeLog('■ probable → central\'s full best plausible case (combined path; t=1 is a plausible scenario, not extrapolation)');
  60: const ts = [], tms = [];
  61: for (let i = 0; i <= 16; i++) { const t = i / 8; const m = estimand(lerp(t), { nWorlds: NW }).m_hat; ts.push(t); tms.push(m); }
  62: let tf = null;
  63: for (let i = 0; i < ts.length - 1; i++) if ((tms[i] > 0) !== (tms[i + 1] > 0)) { tf = ts[i] + (0 - tms[i]) * (ts[i + 1] - ts[i]) / (tms[i + 1] - tms[i]); break; }
  64: safeLog(`    t=0 probable scenario → t=1 central's full best plausible case`);
  65: safeLog(`    m across t: ` + ts.filter((_, i) => i % 2 === 0).map((t, i) => `t=${t.toFixed(2)}:${pct(tms[i * 2])}`).join('  '));
  66: safeLog(tf === null
  67:   ? `    frontier: none in t∈[0,2] — one endpoint does not cross parity`
  68:   : `    frontier (m=0) at t ≈ ${tf.toFixed(2)}  →  conditions ${tf < 1 ? `~${Math.round(tf * 100)}% of the way from probable to the declared central-favourable endpoint flip the winner to the central (within the declared interpolation segment)` : `must exceed the declared central-favourable endpoint (t>1)`}`);
  69: safeLog('');
  70: safeLog('Read: none of the FIVE plotted one-factor slices flips the winner from the probable scenario over its plotted');
  71: safeLog('range (a limited robustness statement over those five slices, NOT over all parameters). The frontier is reached');
  72: safeLog('on the combined path within the declared interpolation segment. NOTE: t is a linear mix of heterogeneous knobs,');
  73: safeLog('an illustrative path — not a calibrated competence scale.');
