   1: // E4 v1.14 — acceptance fixtures (capability criterion) + embargo self-tests. Run: npm run e4:test
   2: // Proves the pipeline SURFACES a strong distributed win, a strong central win, and a null when each is the ground
   3: // truth — i.e. results are surfaced, not selected-in or washed out. Plus: the closed schema + embargo reject
   4: // forbidden multiplier/ratio notation.
   5: import { execSync } from 'node:child_process';
   6: import { baseConfig, validateConfig } from './contract.mjs';
   7: import { estimand } from './engine.mjs';
   8: import { assertNoEmbargoedTokens } from './adapter.mjs';
   9: import { validateOutput } from './schema.mjs';
  10: import { classify } from './evidence.mjs';
