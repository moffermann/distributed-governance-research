   1: // E4 v1.14 — negative controls. These MUST pass or the model is not trustworthy (DESIGN_SKETCH_v5 §5).
   2: // Run: node scripts/simulation/e4-v5/controls.mjs
   3: import { baseConfig } from './contract.mjs';
   4: import { makeRng, runWorld, estimand } from './engine.mjs';
   5: 
   6: const SMALL = { N: 900, K: 120 };            // smaller world for fast, still-meaningful controls (both within D_M)
   7: const NW = 300, SEED = 20260711;
   8: 
   9: // run NW worlds, return per-world {D,C,O} arrays (common random numbers => aligned across configs)
  10: function runWorlds(cfg) {
  11:   const rng = makeRng(SEED);
  12:   const out = [];
  13:   for (let i = 0; i < NW; i++) { const r = runWorld(cfg, rng); if (!r.empty) out.push(r); }
  14:   return out;
  15: }
  16: const maxAbsDiff = (a, b, key) => Math.max(...a.map((x, i) => Math.abs(x[key] - b[i][key])));
  17: const pass = (name, ok, detail) => console.log(`${ok ? 'PASS' : 'FAIL'}  ${name}${detail ? '  — ' + detail : ''}`);
  18: 
  19: let allOk = true;
  20: const check = (name, ok, detail) => { pass(name, ok, detail); allOk = allOk && ok; };
  21: 
  22: // ---- Control 1: signal recovery + exact joint symmetry ----
  23: // a=w=0, b=1, sigma_C=0, b_H_C=1, s_exp=0 (gate=1 everywhere) => M_C = S+ - H = S.
  24: // p=1, beta=0, sigma_e=0 => everyone reports truthfully => M_D = S. All three arms == oracle => D=C=O => m=0.
  25: {
  26:   const cfg = { ...baseConfig(), ...SMALL,
  27:     a: 0, w: 0, b: 1, sigma_C: 0, b_H_C: 1, s_exp: 0, lambda: 0,
  28:     p: 1, beta: 0, sigma_e: 0 };
  29:   const worlds = runWorlds(cfg);
  30:   const maxDC = Math.max(...worlds.map((x) => Math.abs(x.D - x.C)));
  31:   const maxDO = Math.max(...worlds.map((x) => Math.abs(x.D - x.O)));
  32:   const { m_hat } = estimand(cfg, { nWorlds: NW });
  33:   check('C1 signal recovery: M_C=M_D=S => D=C=O', maxDC < 1e-9 && maxDO < 1e-9, `max|D-C|=${maxDC.toExponential(2)}, max|D-O|=${maxDO.toExponential(2)}`);
  34:   check('C1 estimand m == 0', Math.abs(m_hat) < 1e-9, `m=${m_hat.toExponential(2)}`);
  35: }
  36: 
  37: // ---- Control 2: credit channel is ACTIVE (and structurally inert at lambda=0) ----
  38: // Credit salience P=V feeds the central rank only through lambda; at lambda=0 the term is multiplied by 0 (inert by
  39: // construction), so the meaningful test is that raising lambda actually changes the central selection.
  40: {
  41:   const base = { ...baseConfig(), ...SMALL };
  42:   const A = runWorlds({ ...base, lambda: 0 });
  43:   const Bb = runWorlds({ ...base, lambda: 0.4 });
  44:   const d = maxAbsDiff(A, Bb, 'C');
  45:   check('C2 credit channel active (C changes with lambda)', d > 1e-9, `max|dC|=${d.toExponential(2)}`);
  46: }
  47: 
  48: // ---- Control 3: pathway inactivation — projection (w=0) ----
  49: // At w=0, the planner position v_p must not affect M_C: varying v_p0 leaves C unchanged world-by-world.
  50: {
  51:   const base = { ...baseConfig(), ...SMALL, w: 0 };
  52:   const A = runWorlds({ ...base, v_p0: 0.6 });
  53:   const Bb = runWorlds({ ...base, v_p0: 3.0 });
  54:   check('C3 w=0 => planner position inert', maxAbsDiff(A, Bb, 'C') < 1e-9, `max|dC|=${maxAbsDiff(A, Bb, 'C').toExponential(2)}`);
  55: }
  56: 
  57: // ---- Control 4: harm channel is ACTIVE and directional ----
  58: // At s_exp=0 (gate=1 everywhere), raising central harm-detection b_H_C from 0 -> 1 should move central toward the
  59: // oracle (it stops overvaluing harmful projects). Expect m(theta)=E[(D-C)/O] to DECREASE (central improves).
  60: {
  61:   const base = { ...baseConfig(), ...SMALL, s_exp: 0 };
  62:   const blind = estimand({ ...base, b_H_C: 0 }, { nWorlds: NW }).m_hat;
  63:   const sighted = estimand({ ...base, b_H_C: 1 }, { nWorlds: NW }).m_hat;
  64:   check('C4 harm channel active (m falls as central sees harm)', sighted < blind - 1e-4, `m(b_H_C=0)=${blind.toFixed(4)} -> m(b_H_C=1)=${sighted.toFixed(4)}`);
  65: }
  66: 
  67: // ---- Baseline descriptive run (not a pass/fail) ----
  68: {
  69:   const cfg = { ...baseConfig(), ...SMALL };
  70:   const r = estimand(cfg, { nWorlds: NW });
  71:   console.log(`\nBaseline (defaults, SMALL world): m_hat=${r.m_hat.toFixed(4)}  CI=[${r.ci[0].toFixed(4)}, ${r.ci[1].toFixed(4)}]  pi_deg=${r.pi_deg.toFixed(3)}  kept=${r.n_kept}/${r.n_worlds}`);
  72: }
  73: 
  74: console.log(`\n${allOk ? 'ALL CONTROLS PASSED' : 'SOME CONTROLS FAILED'}`);
  75: process.exit(allOk ? 0 : 1);
===== scripts/simulation/e4-v5/engine.mjs =====
   1: // E4 v1.14 — fresh mean-scale engine, driven ONLY by the contract.
   2: // Implements DESIGN_SKETCH_v5 §1-§2: anti-value (S = S+ - H), the behavioral coverage estimator (MNAR mean), and
   3: // the central salience-gated harm-myopia model. All value quantities are per-interested-person means. Every literal
   4: // the engine uses comes from the contract; validateConfig() is called before any run (fail-closed).
   5: 
   6: import { THETA, NUM, CLASSIFY, validateConfig, validateDomain } from './contract.mjs';
   7: 
   8: // ---------------- seeded PRNG (Date.now / Math.random forbidden for reproducibility) ----------------
   9: export function makeRng(seed) {
  10:   let s = seed >>> 0;
  11:   const u = () => { // mulberry32
  12:     s |= 0; s = (s + 0x6D2B79F5) | 0;
  13:     let t = Math.imul(s ^ (s >>> 15), 1 | s);
  14:     t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
  15:     return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  16:   };
  17:   let spare = null;
  18:   const normal = () => { // Box-Muller with cached spare
  19:     if (spare !== null) { const v = spare; spare = null; return v; }
  20:     let a = u(); if (a < 1e-12) a = 1e-12;
  21:     const b = u();
  22:     const r = Math.sqrt(-2 * Math.log(a)), th = 2 * Math.PI * b;
  23:     spare = r * Math.sin(th);
  24:     return r * Math.cos(th);
  25:   };
  26:   const exponential = (mean) => -mean * Math.log(1 - u() + 1e-12);
  27:   const gamma = (k) => { // Marsaglia-Tsang
  28:     if (k < 1) return gamma(k + 1) * Math.pow(u() + 1e-12, 1 / k);
  29:     const d = k - 1 / 3, c = 1 / Math.sqrt(9 * d);
  30:     for (;;) {
  31:       let x, v;
  32:       do { x = normal(); v = 1 + c * x; } while (v <= 0);
  33:       v = v * v * v;
  34:       const uu = u();
  35:       if (uu < 1 - 0.0331 * x * x * x * x) return d * v;
  36:       if (Math.log(uu + 1e-12) < 0.5 * x * x + d * (1 - v + Math.log(v))) return d * v;
  37:     }
  38:   };
  39:   const beta = (a, b) => { const ga = gamma(a), gb = gamma(b); return ga / (ga + gb); };
  40:   const binomialApprox = (n, prob) => {
  41:     if (n <= 0 || prob <= 0) return 0;
  42:     if (prob >= 1) return n;
  43:     const m = n * prob, sd = Math.sqrt(n * prob * (1 - prob));
  44:     return Math.max(0, Math.min(n, Math.round(m + sd * normal())));
  45:   };
  46:   return { u, normal, exponential, gamma, beta, binomialApprox };
  47: }
  48: 
  49: // ---------------- world generation (one economy of projects) ----------------
  50: // Returns an array of admissible projects, each with true net value S, cost c, and the three arms' signals.
  51: export function generateWorld(cfg, rng) {
  52:   const projects = [];
  53:   for (let j = 0; j < cfg.K; j++) {
  54:     const q = cfg.m_q + cfg.s_q * rng.normal();
  55:     const V = rng.beta(cfg.a_V, cfg.b_V);                       // visibility in [0,1], heavy-tailed toward 0
  56:     const qStd = cfg.s_q > 0 ? (q - cfg.m_q) / cfg.s_q : 0;
  57:     const g = cfg.zeta * qStd + Math.sqrt(Math.max(0, 1 - cfg.zeta * cfg.zeta)) * rng.normal();
  58:     const c = cfg.c_lo + (cfg.c_hi - cfg.c_lo) * rng.u();
  59:     const r = rng.beta(cfg.a_r, cfg.b_r);
  60:     const n = rng.binomialApprox(cfg.N, r);
  61:     if (n === 0) continue;                                      // inadmissible in ALL arms (dropped, counted below)
  62: 
  63:     let sumPos = 0, sumNeg = 0, sumReport = 0;
  64:     for (let i = 0; i < n; i++) {
  65:       let u = q + cfg.sigma * rng.normal();
  66:       if (rng.u() < cfg.pi_opp) u -= rng.exponential(cfg.mu_opp);   // intense-minority opposition
  67:       if (u >= 0) sumPos += u; else sumNeg += -u;
  68:       const reportProb = u >= 0 ? cfg.p : cfg.p * (1 - cfg.beta);
  69:       if (rng.u() < reportProb) sumReport += (u + cfg.sigma_e * rng.normal()) / cfg.p;
  70:     }
  71:     const Splus = sumPos / n;                                   // support (mean of positive parts)
  72:     const H = sumNeg / n;                                       // harm (mean opposition intensity)
  73:     const S = Splus - H;                                        // true net value (mean scale)
  74:     const M_D = sumReport / n;                                  // behavioral coverage estimator; E[M_D|u]=S+ -(1-beta)H
  75: 
  76:     const v_pj = cfg.v_p0 + cfg.gamma * g + cfg.sigma_v * rng.normal();
  77:     const sV = Math.pow(Math.max(0, Math.min(1, V)), cfg.s_exp);// harm gate: ~0 on long tail, ~1 when salient
  78:     const M_C = cfg.a + cfg.b * Splus + cfg.w * (v_pj - Splus) - cfg.b_H_C * sV * H + cfg.sigma_C * rng.normal();
  79: 
  80:     const P = V;                                               // visible salience -> credit (linear scale would cancel under z)
  81:     projects.push({ S, c, M_C, M_D, P });
  82:   }
  83:   return projects;
  84: }
  85: 
  86: // ---------------- selection: one common interface for all three arms ----------------
  87: function zscore(vals, fallbackSd) {
  88:   const n = vals.length;
  89:   if (n === 0) return [];
  90:   const mean = vals.reduce((s, x) => s + x, 0) / n;
  91:   let v = 0; for (const x of vals) v += (x - mean) * (x - mean);
  92:   let sd = Math.sqrt(v / n);
  93:   if (!(sd > 0)) sd = fallbackSd;
  94:   return vals.map((x) => (x - mean) / sd);
  95: }
  96: 
  97: // Fund greedily by rank score among the arm's own eligible set, under budget, exact residual fill, tie-break lower j.
  98: function fundedValue(projects, signalKey, cfg, budget, opts = {}) {
  99:   const idx = [];
 100:   for (let j = 0; j < projects.length; j++) {
 101:     const x = projects[j][signalKey];
 102:     if (x - cfg.h * projects[j].c > 0) idx.push(j);            // own-estimate eligibility gate
 103:   }
 104:   if (idx.length === 0) return 0;
 105:   const rawVal = idx.map((j) => (projects[j][signalKey] - cfg.h * projects[j].c) / projects[j].c);
 106:   let score = zscore(rawVal, NUM.z_fallback_sd.value);
 107:   if (opts.creditTilt) {                                        // central credit tilt
 108:     const zP = zscore(idx.map((j) => projects[j].P / projects[j].c), NUM.z_fallback_sd.value);
 109:     score = score.map((s, t) => (1 - cfg.lambda) * s + cfg.lambda * zP[t]);
 110:   }
 111:   const order = idx.map((j, t) => ({ j, s: score[t] }))
 112:     .sort((A, B) => (B.s - A.s) || (A.j - B.j));               // desc score, tie-break lower index
 113:   let spent = 0, delivered = 0;
 114:   for (const { j } of order) {
 115:     if (spent + projects[j].c <= budget) { spent += projects[j].c; delivered += projects[j].S; }
 116:   }
 117:   return delivered;
 118: }
 119: 
 120: export function runWorld(cfg, rng) {
 121:   const projects = generateWorld(cfg, rng);
 122:   if (projects.length === 0) return { D: 0, C: 0, O: 0, empty: true };
 123:   let totalCost = 0; for (const pr of projects) totalCost += pr.c;
 124:   const budget = cfg.phi * totalCost;
 125:   const O = fundedValue(projects, 'S',   cfg, budget);
 126:   const C = fundedValue(projects, 'M_C', cfg, budget, { creditTilt: true });
 127:   const D = fundedValue(projects, 'M_D', cfg, budget);
 128:   return { D, C, O, empty: false };
 129: }
 130: 
 131: // ---------------- estimand m(theta) = E[(D-C)/O | O>o_min], plus pi_deg ----------------
 132: function median(arr) {
 133:   if (arr.length === 0) return 0;
 134:   const a = [...arr].sort((x, y) => x - y);
 135:   const mid = a.length >> 1;
 136:   return a.length % 2 ? a[mid] : 0.5 * (a[mid - 1] + a[mid]);
 137: }
 138: 
 139: export function estimand(cfg, { nWorlds = NUM.n_worlds.value, seed = NUM.seed.value, oMinAbs = null } = {}) {
 140:   validateConfig(cfg);
 141:   validateDomain(cfg);
 142:   const rng = makeRng(seed);
 143:   const worlds = [];
 144:   for (let wI = 0; wI < nWorlds; wI++) {
 145:     const { D, C, O, empty } = runWorld(cfg, rng);
 146:     if (!empty) worlds.push({ D, C, O });
 147:   }
 148:   const Os = worlds.map((x) => x.O);
 149:   // o_min is an ABSOLUTE floor (default from this config's own median). Passing oMinAbs pins ONE floor across a
 150:   // whole sweep, so degenerate corners (tiny O => exploding (D-C)/O) get most worlds excluded and flagged, rather
 151:   // than injecting divergent ratios into the envelope (Codex: denominator-weighting divergence).
 152:   const o_min = oMinAbs !== null ? oMinAbs : CLASSIFY.o_min_frac.value * median(Os);
 153:   const kept = worlds.filter((x) => x.O > o_min);
 154:   const degCount = worlds.length - kept.length;
 155:   const pi_deg = worlds.length ? degCount / worlds.length : 1;
 156:   // RATIO OF SUMS (robust): m = Σ(D−C)/ΣO over retained worlds. Bounded and stable — a single tiny-O world cannot
 157:   // dominate (as it would in the per-world-ratio mean, Codex's (1,1)/(−1,100) divergence). Interpretation: total
 158:   // true value the arm delivers, as a fraction of the total full-information achievable value.
 159:   const num = kept.reduce((s, x) => s + (x.D - x.C), 0);
 160:   const den = kept.reduce((s, x) => s + x.O, 0);
 161:   const m_hat = den > 0 ? num / den : NaN;
 162: 
 163:   // world-cluster bootstrap CI (inner simulation variability only): resample worlds, recompute the ratio of sums.
 164:   const B = NUM.bootstrap_reps.value;
 165:   const bootRng = makeRng((seed ^ 0x9e3779b9) >>> 0);
 166:   const boots = [];
 167:   if (kept.length) {
 168:     for (let bI = 0; bI < B; bI++) {
 169:       let bn = 0, bd = 0;
 170:       for (let t = 0; t < kept.length; t++) { const w = kept[Math.floor(bootRng.u() * kept.length)]; bn += (w.D - w.C); bd += w.O; }
 171:       if (bd > 0) boots.push(bn / bd);
 172:     }
 173:     boots.sort((a, b) => a - b);
 174:   }
 175:   const lo = boots.length ? boots[Math.floor((1 - NUM.ci_level.value) / 2 * boots.length)] : NaN;
 176:   const hi = boots.length ? boots[Math.floor((1 + NUM.ci_level.value) / 2 * boots.length) - 1] : NaN;
 177: 
 178:   const sumD = kept.reduce((s, x) => s + x.D, 0), sumC = kept.reduce((s, x) => s + x.C, 0);
 179:   const dOverO = den > 0 ? sumD / den : NaN, cOverO = den > 0 ? sumC / den : NaN;  // efficiency of each arm vs oracle
 180:   const enough = kept.length >= Math.max(NUM.min_kept_floor.value, NUM.min_kept_frac.value * worlds.length);
 181:   return { m_hat, ci: [lo, hi], pi_deg, n_kept: kept.length, n_worlds: worlds.length, o_min, enough, dOverO, cOverO };
 182: }
===== scripts/simulation/e4-v5/evidence.mjs =====
   1: // E4 v1.14 — the exclusive evidence path (`npm run e4:evidence`). v7: the GLOBAL "report everything" object is a
   2: // uniform Monte-Carlo over the ANCHORED scenario envelope (per knob = [min,max] of the three anchored scenarios in
   3: // research/e4-plausible-anchors.md) — a DEFENSIBLE box, not the arbitrary raw D_F (uniform over a too-wide D_F would
   4: // distort the sign fraction). It reports: the PROBABLE headline point m ± 95% CI, and across the plausible envelope
   5: // the DISTRIBUTION of m (p5/p50/p95) and the VOLUME fraction where each institution wins (with binomial SE). Sign is
   6: // classified from those volume fractions. Every output byte is routed through the sole embargo adapter.
   7: import { fileURLToPath } from 'node:url';
   8: import { THETA, NUM, CLASSIFY, EVIDENCE, baseConfig, resolvedHash, contractHash, inRalpha, CONTRACT_VERSION } from './contract.mjs';
   9: import { estimand, makeRng } from './engine.mjs';
  10: import { PRO_CENTRAL, PROBABLE, PRO_DIST, SCENARIO_WORLD as WORLD } from './scenario-configs.mjs';
  11: 
  12: // targeted probe of the coordinated central-favourable region: sample within `frac` of the way from PRO_CENTRAL
  13: // toward PROBABLE, report the fraction of draws the central wins (the product-box sampler misses this region).
  14: function centralRegionProbe(nWorlds, n, frac) {
  15:   const base = { ...baseConfig(), ...WORLD };
  16:   const keys = Object.keys(PROBABLE);
  17:   const rng = makeRng((NUM.seed.value ^ 0x2545f491) >>> 0);
  18:   let cen = 0, ok = 0;
  19:   for (let i = 0; i < n; i++) {
  20:     const cfg = { ...base, ...PRO_CENTRAL };
  21:     for (const k of keys) cfg[k] = PRO_CENTRAL[k] + rng.u() * frac * (PROBABLE[k] - PRO_CENTRAL[k]);
  22:     const r = estimand(cfg, { nWorlds, seed: NUM.seed.value });
  23:     if (!r.enough || !Number.isFinite(r.m_hat)) continue;
  24:     ok++; if (r.m_hat < -CLASSIFY.zero_tol.value) cen++;
  25:   }
  26:   return { cenFrac: ok ? cen / ok : NaN, cen, ok };
  27: }
  28: import { renderReport, assertNoEmbargoedTokens } from './adapter.mjs';
  29: import { validateOutput } from './schema.mjs';
  30: 
  31: const SEED = NUM.seed.value;
  32: const SWEPT = Object.keys(PROBABLE);   // the knobs varied by the anchored scenarios
  33: const ENV = Object.fromEntries(SWEPT.map((k) => {
  34:   const vals = [PRO_CENTRAL[k], PROBABLE[k], PRO_DIST[k]].filter((v) => v !== undefined);
  35:   return [k, [Math.min(...vals), Math.max(...vals)]];
  36: }));
  37: 
  38: const MANIFEST = {
  39:   contract_version: CONTRACT_VERSION, contract_hash: contractHash(), world: WORLD, seed: SEED,
  40:   probable_nw: EVIDENCE.probable_nw, sweep_nw: EVIDENCE.sweep_nw, n_env: EVIDENCE.n_env,
  41:   swept: SWEPT, envelope: ENV, fixed: EVIDENCE.fixed,
  42:   o_min_frac: CLASSIFY.o_min_frac.value, delta: CLASSIFY.delta.value, zero_tol: CLASSIFY.zero_tol.value,
  43:   estimand: 'ratio-of-sums Sum(D-C)/Sum(O) over kept worlds; headline = PROBABLE scenario m+-CI; global = uniform MC over the anchored envelope -> sign VOLUME fractions (with SE) + m distribution p5/p50/p95',
  44: };
  45: const THETA_ID = 'e4v7+' + resolvedHash(MANIFEST);
  46: 
  47: const pctl = (arr, q) => { if (!arr.length) return NaN; const a = [...arr].sort((x, y) => x - y); const i = Math.min(a.length - 1, Math.max(0, Math.round(q * (a.length - 1)))); return a[i]; };
  48: 
  49: // uniform Monte-Carlo over the anchored envelope: fraction of samples where each arm wins (volume, with SE) + m dist.
  50: function envelopeSweep(nWorlds, n) {
  51:   const base = { ...baseConfig(), ...WORLD };
  52:   const rng = makeRng((SEED ^ 0x5bd1e995) >>> 0);
  53:   const ms = []; let pos = 0, neg = 0, par = 0, resolved = 0;
  54:   const zt = CLASSIFY.zero_tol.value;
  55:   for (let i = 0; i < n; i++) {
  56:     const cfg = { ...base, ...PROBABLE };
  57:     for (const k of SWEPT) cfg[k] = ENV[k][0] + (ENV[k][1] - ENV[k][0]) * rng.u();
  58:     const r = estimand(cfg, { nWorlds, seed: SEED });
  59:     if (!r.enough || !Number.isFinite(r.m_hat)) continue;
  60:     resolved++; ms.push(r.m_hat);
  61:     if (r.m_hat > zt) pos++; else if (r.m_hat < -zt) neg++; else par++;
  62:   }
  63:   const share = (c) => (resolved ? c / resolved : NaN);
  64:   const se = (p) => (resolved ? Math.sqrt(Math.max(0, p * (1 - p)) / resolved) : NaN);
  65:   return { resolved, n, distShare: share(pos), centShare: share(neg), parShare: share(par),
  66:     distShareSE: se(share(pos)), p5: pctl(ms, 0.05), p50: pctl(ms, 0.50), p95: pctl(ms, 0.95),
  67:     enough: resolved >= EVIDENCE.n_env * 0.5 };
  68: }
  69: 
  70: export function classify({ point, dfEnv, ralphaHeadline, pi_deg, enough }) {
  71:   const d = CLASSIFY.delta.value;
  72:   let sign_status;
  73:   if (dfEnv.distShare > 0 && dfEnv.centShare > 0) sign_status = 'indeterminate';
  74:   else if (dfEnv.distShare > 0 && dfEnv.centShare === 0) sign_status = 'pos';
  75:   else if (dfEnv.centShare > 0 && dfEnv.distShare === 0) sign_status = 'neg';
  76:   else sign_status = 'zero-touching';
  77:   const [rl, rh] = ralphaHeadline;
  78:   let materiality_status;
  79:   if (rl > d || rh < -d) materiality_status = 'material';
  80:   else if (rl > -d && rh < d) materiality_status = 'negligible';
  81:   else materiality_status = 'uncertain';
  82:   const degeneracy_status = pi_deg >= 1 ? 'degenerate' : (pi_deg > CLASSIFY.pi_deg_warn.value ? 'high' : 'ok');
  83:   const numerical_status = (enough && dfEnv.enough && (point.ci[1] - point.ci[0]) < d) ? 'resolved' : 'unresolved';
  84:   return { sign_status, materiality_status, degeneracy_status, numerical_status };
  85: }
  86: 
  87: export function buildEvidence() {
  88:   const base = { ...baseConfig(), ...WORLD };
  89:   if (!inRalpha(base, ['N', 'K'])) throw new Error('[evidence] world N/K outside declared R_alpha');
  90:   const pt = estimand({ ...base, ...PROBABLE }, { nWorlds: EVIDENCE.probable_nw, seed: SEED });   // PROBABLE headline
  91:   if (!pt.enough) throw new Error(`[evidence] probable point insufficient: ${pt.n_kept} kept — aborting fail-closed`);
  92: 
  93:   const env = envelopeSweep(EVIDENCE.sweep_nw, EVIDENCE.n_env);
  94:   if (env.resolved === 0) throw new Error('[evidence] envelope sweep has no resolved samples — aborting fail-closed');
  95:   const centralRegion = centralRegionProbe(EVIDENCE.sweep_nw, 40, 0.2);   // 20%-inward neighbourhood of PRO_CENTRAL
  96: 
  97:   const st = classify({ point: pt, dfEnv: env, ralphaHeadline: pt.ci, pi_deg: pt.pi_deg, enough: pt.enough });
  98:   // the product-box sampler is Core-v0-heavy, but a coordinated central-favourable region exists (targeted probe) —
  99:   // so the GLOBAL sign is region-dependent (indeterminate), not the box sampler's one-sided result.
 100:   if (centralRegion.cenFrac > 0 && env.distShare > 0) st.sign_status = 'indeterminate';
 101:   const out = {
 102:     contract_version: CONTRACT_VERSION, theta_id: THETA_ID, pi_deg: pt.pi_deg,
 103:     m_hat: pt.m_hat, ci: pt.ci,
 104:     df_dist_share: env.distShare, df_cent_share: env.centShare, df_par_share: env.parShare, df_dist_share_se: env.distShareSE,
 105:     ...st,
 106:   };
 107:   const errs = validateOutput(out);
 108:   if (errs.length) throw new Error('[evidence] output invalid: ' + errs.join('; '));
 109:   return { out, env, pt, centralRegion, manifest: MANIFEST };
 110: }
 111: 
 112: function main() {
 113:   const { out, env, pt, centralRegion } = buildEvidence();
 114:   const P = (x) => (x >= 0 ? '+' : '') + (100 * x).toFixed(1) + '%';
 115:   const sh = (x) => (100 * x).toFixed(0) + '%';
 116:   const ruleOf3 = env.centShare === 0 ? (3 / env.resolved) : NaN;   // one-sided 95% upper bound when 0 observed
 117:   const text = [
 118:     `E4 evidence — contract ${out.contract_version} — θ:${out.theta_id}`,
 119:     `  PROBABLE scenario (source-motivated declared reference) headline: m = ${P(out.m_hat)}  95% CI [${P(out.ci[0])}, ${P(out.ci[1])}]   Core v0 ${P(pt.dOverO)} of oracle · central ${P(pt.cOverO)}`,
 120:     `  finite product-box sample of the declared envelope (${env.resolved}/${env.n} draws, knobs independent uniform):`,
 121:     `    m distribution: p5 ${P(env.p5)} · median ${P(env.p50)} · p95 ${P(env.p95)}`,
 122:     `    Core v0 wins ${env.resolved - Math.round(env.centShare * env.resolved) - Math.round(env.parShare * env.resolved)}/${env.resolved} draws · central ${Math.round(env.centShare * env.resolved)} · parity ${Math.round(env.parShare * env.resolved)}` +
 123:       (Number.isFinite(ruleOf3) ? `   (0 central: one-sided 95% upper bound on central-win prob ≈ ${sh(ruleOf3)}, rule of three — NOT zero)` : ''),
 124:     `  targeted probe of the coordinated central-favourable region (20% inward of PRO-CENTRAL): central wins ${centralRegion.cen}/${centralRegion.ok} draws`,
 125:     `    ⇒ a real central-winning region EXISTS off the independent-box sample; the GLOBAL winner is region-dependent, not one-sided`,
 126:     `  status → sign:${out.sign_status} (region-dependent)  materiality:${out.materiality_status}  degeneracy:${out.degeneracy_status}  numerical:${out.numerical_status}`,
 127:     `  π_deg: ${sh(out.pi_deg)}   contract hash: ${MANIFEST.contract_hash}`,
 128:     `  (named scenarios & frontiers: npm run e4:scenarios / e4:frontier — see research/e4-plausible-anchors.md)`,
 129:   ].join('\n');
 130:   assertNoEmbargoedTokens(text);
 131:   console.log(text);
 132: }
