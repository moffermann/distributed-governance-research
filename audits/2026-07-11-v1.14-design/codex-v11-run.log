  14: const CONF_X = /[×✕✖⨯хХｘＸ]/g;               // → x
  15: const CONF_HYPHEN = /[‐‑‒–—]/g; // various hyphens/dashes → '-'
  16: const CONF_SLASH = /[⁄∕／]/g;   // fraction/division/fullwidth slash → '/'
  17: const NUMWORD = 'one|two|three|four|five|six|seven|eight|nine|ten|twenty|thirty|forty|fifty|hundred|thousand|many|several';
  18: const MULT_SUFFIX = /\d\s*x/i;                 // a number followed by x (after normalization)
  19: const NUM_FOLD    = new RegExp(`(\\d(\\.\\d+)?|\\b(${NUMWORD}))[\\s-]*(fold|times)\\b`, 'i');   // "2.2-fold","two times","fourfold"
  20: const WORD_MULT   = /\b(twice|thrice|double|triple|quadruple)\b/i;   // bare word multipliers
  21: const RATIO_TOKEN = /\b[dc]\s*\/\s*[cd]\b/i;   // D/C or C/D, any case
  22: 
  23: // NOTE: this rejects the TESTED token classes (ASCII/Unicode/confusable/HTML-entity 'x' after a number;
  24: // numeric or number-word N-fold / N-times; bare twice/double/triple/quadruple; D/C or C/D any case; zero-width
  25: // splits). It is not a proof against every conceivable obfuscation — see the test suite for the covered classes.
  26: export function assertNoEmbargoedTokens(text) {
  27:   const norm = text.replace(ZERO_WIDTH, '').replace(HTML_MULT, 'x').replace(CONF_X, 'x').replace(CONF_HYPHEN, '-').replace(CONF_SLASH, '/');
  28:   const hits = [];
  29:   if (MULT_SUFFIX.test(norm)) hits.push('multiplier-suffix (number+x, incl. Unicode/HTML confusables)');
  30:   if (NUM_FOLD.test(norm)) hits.push('N-fold / N-times multiplier phrasing (numeric or word)');
  31:   if (WORD_MULT.test(norm)) hits.push('word multiplier (twice/thrice/double/triple/quadruple)');
  32:   if (RATIO_TOKEN.test(norm)) hits.push('institution ratio (D/C or C/D, any case)');
  33:   for (const tok of EMBARGO_TOKENS) if (text.includes(tok)) hits.push(`token '${tok}'`);
  34:   if (hits.length) throw new Error(`[embargo] rendered text contains forbidden performance notation: ${hits.join(', ')}`);
  35:   return true;
  36: }
  37: 
  38: // A print helper that routes every line through the embargo before emitting (for scenarios/frontier that print directly).
  39: export function safeLog(...lines) { const t = lines.join(' '); assertNoEmbargoedTokens(t); console.log(t); }
  40: 
  41: export function renderReport(out) {
  42:   const errs = validateOutput(out);
  43:   if (errs.length) throw new Error(`[embargo] output failed closed schema: ${errs.join('; ')}`);
  44:   const pct = (x) => (100 * x).toFixed(1) + '%';                 // signed fraction of oracle, NOT a multiplier
  45:   const mag = out.m_Ralpha
  46:     ? Object.entries(out.m_Ralpha).map(([al, iv]) => `  α=${al}: [${pct(iv[0])}, ${pct(iv[1])}] of oracle`).join('\n')
  47:     : '  (magnitude layer not computed)';
  48:   const sh = (x) => (100 * x).toFixed(0) + '%';
  49:   const text = [
  50:     `E4 evidence — contract ${out.contract_version} — θ:${out.theta_id}`,
  51:     `  m̂ (signed fraction of full-information oracle, parity at 0): ${pct(out.m_hat)}  CI=[${pct(out.ci[0])}, ${pct(out.ci[1])}]`,
  52:     `  sign backbone over D_F: Core v0 wins ${sh(out.df_dist_share)} of sampled θ-points · central ${sh(out.df_cent_share)} · parity ${sh(out.df_par_share)}  (a COUNT of resolved points, not a probability)`,
  53:     `  magnitude over R_α (declared sensitivity boxes; a value >100% means the losing arm destroys value, so the gap exceeds the oracle):`,
  54:     mag,
  55:     `  status → sign:${out.sign_status}  materiality:${out.materiality_status}  degeneracy:${out.degeneracy_status}  numerical:${out.numerical_status}`,
  56:     `  π_deg (degenerate-world share): ${pct(out.pi_deg)}`,
  57:   ].join('\n');
  58:   assertNoEmbargoedTokens(text);
  59:   return text;
  60: }
===== scripts/simulation/e4-v5/atlas.mjs =====
   1: // E4 v1.14 — parity ATLAS (visualization only; does not touch the model). Sweeps TWO axes and reports m(theta)
   2: // at each cell, holding all other parameters at their registered defaults. This is an explicit 2-axis SLICE
   3: // (honest by construction — it does not claim to be the full 30-parameter joint set). Output:
   4: //   (1) an accessible numeric grid + ASCII heat map to the console (primary, screen-reader friendly), and
   5: //   (2) a JSON grid written to atlas-data.json for a color heatmap artifact.
   6: // Run: node scripts/simulation/e4-v5/atlas.mjs
   7: import { writeFileSync } from 'node:fs';
   8: import { baseConfig, THETA } from './contract.mjs';
   9: import { estimand } from './engine.mjs';
  10: 
  11: const WORLD = { N: 1200, K: 130 };
  12: const NW = 250;
  13: const STEPS = 11;
  14: 
  15: // Two axes chosen to CROSS the parity frontier (so both colors appear), reflecting the thesis:
  16: //   X = p      (citizen participation / distributed data density: low => distributed noisy & sparse => central wins)
  17: //   Y = s_exp  (central harm myopia: 0 => central sees harm everywhere; high => blind on the long tail => distributed wins)
  18: // All other parameters held at their registered defaults (b_H_C=0.5, beta=0.4, ...). Honest 2-axis slice.
  19: const AX = { key: 'p',     from: 0.02, to: 0.6, label: 'p  citizen participation (→ denser distributed evidence)' };
  20: const AY = { key: 's_exp', from: 0.0,  to: 6.0, label: 's_exp  central harm myopia (→ central blind on the long tail)' };
  21: const HOLD = {};
  22: 
  23: const lin = (a, b, n, i) => a + (b - a) * (i / (n - 1));
  24: const grid = [];       // grid[iy][ix] = m
  25: const xs = [], ys = [];
  26: for (let i = 0; i < STEPS; i++) { xs.push(lin(AX.from, AX.to, STEPS, i)); ys.push(lin(AY.from, AY.to, STEPS, i)); }
  27: 
  28: for (let iy = STEPS - 1; iy >= 0; iy--) {          // top row = highest Y
  29:   const row = [];
  30:   for (let ix = 0; ix < STEPS; ix++) {
  31:     const cfg = { ...baseConfig(), ...WORLD, ...HOLD, [AX.key]: xs[ix], [AY.key]: ys[iy] };
  32:     row.push(estimand(cfg, { nWorlds: NW }).m_hat);
  33:   }
  34:   grid.push(row);
  35: }
  36: 
  37: // ---- ASCII heat map (accessible) ----
  38: // glyph by sign & magnitude: distributed wins (+) as D/d, central wins (-) as C/c, parity as ·
  39: const glyph = (m) => {
  40:   if (m > 0.20) return 'D'; if (m > 0.05) return 'd';
  41:   if (m < -0.20) return 'C'; if (m < -0.05) return 'c';
  42:   return '·';
  43: };
  44: console.log('E4 parity atlas — m(θ) = (D − C)/O, signed fraction of the full-information oracle (parity at 0)');
  45: console.log(`  X → ${AX.label}`);
  46: console.log(`  Y ↑ ${AY.label}`);
  47: console.log('  glyph: D=distributed wins strongly, d=mildly, ·=parity, c=central mildly, C=central strongly\n');
  48: console.log('        ' + xs.map((x) => x.toFixed(2).padStart(6)).join(''));
  49: for (let r = 0; r < STEPS; r++) {
  50:   const yval = ys[STEPS - 1 - r].toFixed(2).padStart(5);
  51:   const glyphs = grid[r].map((m) => glyph(m).padStart(6)).join('');
  52:   console.log(`  ${yval} ${glyphs}`);
  53: }
  54: console.log('\n  numeric grid (%, top row = highest ' + AY.key + '):');
  55: console.log('        ' + xs.map((x) => x.toFixed(2).padStart(7)).join(''));
  56: for (let r = 0; r < STEPS; r++) {
  57:   const yval = ys[STEPS - 1 - r].toFixed(2).padStart(5);
  58:   console.log(`  ${yval} ` + grid[r].map((m) => (100 * m).toFixed(0).padStart(7)).join(''));
  59: }
  60: 
  61: // region shares
  62: let win = 0, lose = 0, par = 0;
  63: for (const row of grid) for (const m of row) { if (m > 0.05) win++; else if (m < -0.05) lose++; else par++; }
  64: const tot = STEPS * STEPS;
  65: console.log(`\n  region shares over this slice: distributed-wins ${(100*win/tot).toFixed(0)}% · parity ${(100*par/tot).toFixed(0)}% · central-wins ${(100*lose/tot).toFixed(0)}%`);
  66: 
  67: writeFileSync(new URL('./atlas-data.json', import.meta.url), JSON.stringify({
  68:   xKey: AX.key, yKey: AY.key, xLabel: AX.label, yLabel: AY.label, hold: HOLD, world: WORLD, nWorlds: NW,
  69:   xs, ys: [...ys], grid, note: 'grid[0] = highest Y row; m = (D-C)/O signed fraction of oracle',
  70: }, null, 2));
  71: console.log('\n  wrote atlas-data.json');
===== scripts/simulation/e4-v5/contract.mjs =====
   1: // E4 v1.14 — MACHINE-READABLE MODEL CONTRACT (single source of truth)
   2: // Codex's single sharpest improvement: one versioned, outcome-blind contract that is the ONLY path to evidence.
   3: // It enumerates theta_all, numerical constants, joint D_F / R_alpha sets, o_min/delta, classification thresholds,
   4: // and the closed output schema. `validate()` throws on unknown or unused fields. Nothing in the engine may use a
   5: // literal that is not registered here.
   6: //
   7: // Param `kind`:
   8: //   physical    — a real quantity with a hard physical domain; D_M\D_F is genuine impossibility (prob in [0,1], sd>=0)
   9: //   directional — a theory-backed sign assumption (w,b,b_H_C,gamma >= 0). NOT a physical law: base case keeps the
  10: //                 sign, but a sign-reversal RIVAL model is reported as sensitivity (author decision 2026-07-11).
  11: //   structural  — a shape/location parameter (means, spreads, counts)
  12: //   numerical   — a solver/Monte-Carlo constant
  13: //   normative   — a declared normative choice (aggregation A); never randomized
  14: 
  15: export const CONTRACT_VERSION = 'e4-v5.0.0';
  16: 
  17: // Each entry: { value, kind, dm:[lo,hi], df:[lo,hi], ralpha:[lo,hi], note }
  18: // dm = mathematical domain; df = physically-possible (sign backbone); ralpha = expectable band (magnitude headline).
  19: export const THETA = {
  20:   // ---- population & projects (structural) ----
  21:   N:      { value: 4000, kind: 'structural', dm: [1, Infinity],   df: [100, 100000], ralpha: [1000, 20000], note: 'population size' },
  22:   K:      { value: 200,  kind: 'structural', dm: [2, Infinity],   df: [20, 5000],    ralpha: [80, 800],     note: 'candidate projects' },
  23:   m_q:    { value: 0.4,  kind: 'structural', dm: [-Infinity, Infinity], df: [-5, 5],  ralpha: [0.0, 1.0],    note: 'mean project quality (mean scale)' },
  24:   s_q:    { value: 1.0,  kind: 'physical',   dm: [0, Infinity],   df: [0, 10],       ralpha: [0.5, 2.0],    note: 'sd of project quality' },
  25:   a_V:    { value: 0.5,  kind: 'physical',   dm: [0, Infinity],   df: [0.05, 50],    ralpha: [0.3, 1.0],    note: 'visibility Beta a (a<1 => heavy tail toward 0)' },
  26:   b_V:    { value: 3.0,  kind: 'physical',   dm: [0, Infinity],   df: [0.05, 50],    ralpha: [1.5, 6.0],    note: 'visibility Beta b (mass on low-visibility long tail)' },
  27:   zeta:   { value: 0.6,  kind: 'physical',   dm: [-1, 1],         df: [0, 1],        ralpha: [0.3, 0.85],   note: 'corr(category signal g, quality q)' },
  28:   c_lo:   { value: 1.0,  kind: 'physical',   dm: [0, Infinity],   df: [0.01, 1e6],   ralpha: [0.5, 2.0],    note: 'min cost' },
  29:   c_hi:   { value: 5.0,  kind: 'physical',   dm: [0, Infinity],   df: [0.01, 1e6],   ralpha: [3.0, 10.0],   note: 'max cost' },
  30:   a_r:    { value: 1.2,  kind: 'physical',   dm: [0, Infinity],   df: [0.05, 50],    ralpha: [0.8, 3.0],    note: 'reach Beta a' },
  31:   b_r:    { value: 8.0,  kind: 'physical',   dm: [0, Infinity],   df: [0.05, 50],    ralpha: [4.0, 20.0],   note: 'reach Beta b (most projects reach a minority)' },
  32:   phi:    { value: 0.35, kind: 'physical',   dm: [0, 1],          df: [0.01, 0.99],  ralpha: [0.2, 0.6],    note: 'budget share of total cost' },
  33: 
  34:   // ---- individual value & ANTI-VALUE (opposition != indifference) ----
  35:   sigma:   { value: 1.0,  kind: 'physical', dm: [0, Infinity], df: [0, 10],   ralpha: [0.5, 2.0],  note: 'sd of idiosyncratic taste eps' },
  36:   pi_opp:  { value: 0.15, kind: 'physical', dm: [0, 1],        df: [0, 1],    ralpha: [0.03, 0.35], note: 'prevalence of intense opponents' },
  37:   mu_opp:  { value: 3.0,  kind: 'physical', dm: [0, Infinity], df: [0, 50],   ralpha: [1.0, 6.0],  note: 'mean opposition intensity (Exponential)' },
  38: 
  39:   // ---- distributed arm (coverage) ----
  40:   p:       { value: 0.25, kind: 'physical', dm: [0, 1], df: [1e-3, 1], ralpha: [0.05, 0.6], note: 'participation prob (report if support)' },
  41:   beta:    { value: 0.40, kind: 'physical', dm: [0, 1], df: [0, 1],    ralpha: [0.1, 0.7],  note: 'adverse-voice suppression of opponents' },
  42:   sigma_e: { value: 0.5,  kind: 'physical', dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of report noise' },
  43: 
  44:   // ---- central arm (salience-gated harm myopia) ----
  45:   v_p0:    { value: 0.6,  kind: 'structural',  dm: [-Infinity, Infinity], df: [-5, 5], ralpha: [-0.5, 1.5], note: "planner's own baseline position" },
  46:   gamma:   { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 5],  ralpha: [0.2, 1.2],  note: 'loading of planner projection on category signal g' },
  47:   sigma_v: { value: 0.5,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of projection idiosyncrasy' },
  48:   a:       { value: 0.2,  kind: 'structural',  dm: [-Infinity, Infinity], df: [-5, 5], ralpha: [-0.3, 0.8], note: 'central intercept / systematic level bias' },
  49:   b:       { value: 0.9,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.6, 1.1],  note: 'central responsiveness to SUPPORT S+' },
  50:   w:       { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.2, 1.0],  note: 'directional projection weight' },
  51:   b_H_C:   { value: 0.5,  kind: 'directional', dm: [-Infinity, Infinity], df: [0, 3], ralpha: [0.1, 1.0],  note: 'central harm-detection coefficient (myopia; salience-gated)' },
  52:   s_exp:   { value: 2.0,  kind: 'physical',    dm: [0, Infinity], df: [0.2, 10], ralpha: [1.0, 4.0], note: 'harm-gate exponent: s(V)=V^s_exp (>1 => near-blind on long tail)' },
  53:   sigma_C: { value: 0.5,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0.1, 1.5], note: 'sd of central estimation noise eta' },
  54: 
  55:   // ---- selection ----
  56:   h:       { value: 0.0,  kind: 'physical',    dm: [0, Infinity], df: [0, 10], ralpha: [0, 1.0], note: 'opportunity-cost hurdle (shared across arms)' },
  57:   lambda:  { value: 0.15, kind: 'physical',    dm: [0, 1], df: [0, 1], ralpha: [0, 0.4], note: 'central credit-pressure weight (credit salience P = visibility V; a linear scale on P would cancel under z-scoring, so none is registered)' },
  58: };
  59: 
  60: // Aggregation A is NORMATIVE and declared, never randomized into a prior.
  61: export const AGGREGATION = { primary: 'mean', alternatives: ['harm_weighted'], note: 'A=mean primary; harm-weighted is a SEPARATE declared estimand' };
  62: 
  63: // ---- numerical / Monte-Carlo constants (nu_all) ----
  64: export const NUM = {
  65:   n_worlds:       { value: 1500, note: 'Monte-Carlo worlds per theta' },
  66:   seed:           { value: 20260711, note: 'base PRNG seed (Date.now/Math.random forbidden)' },
  67:   bootstrap_reps: { value: 400,  note: 'world-cluster bootstrap replications (inner variability only)' },
  68:   ci_level:       { value: 0.95, note: 'bootstrap CI level' },
  69:   z_fallback_sd:  { value: 1.0,  note: 'z-score sd fallback when eligible-set sd=0' },
  70:   min_kept_frac:  { value: 0.5,  note: 'a cell is sufficient only if kept/(simulated) worlds >= this' },
  71:   min_kept_floor: { value: 40,   note: 'and kept worlds >= this absolute floor; else numerically-unresolved/degenerate' },
  72: };
  73: 
  74: // ---- estimand thresholds (frozen, mean-value units; NOT the retired 0.05) ----
  75: export const CLASSIFY = {
  76:   o_min_frac:  { value: 0.05, note: 'o_min = o_min_frac * median(O_W); worlds with O<=o_min excluded from m, counted in pi_deg' },
  77:   delta:       { value: 0.03, note: 'materiality band on m (fraction-of-oracle units); justified in delivered-value terms, NOT the 0.05 rebuild gate' },
  78:   zero_tol:    { value: 0.005, note: 'sign_status=zero-touching when |m|<=zero_tol or CI straddles 0 within this' },
  79:   pi_deg_warn: { value: 0.10, note: 'degeneracy_status=high above this share' },
  80: };
  81: 
  82: // alpha coverage family for the magnitude (R_alpha) layer
  83: export const ALPHA_LEVELS = [0.5, 0.8, 0.95];
  84: 
  85: // ---- EVIDENCE configuration (single source of truth for the evidence run; hashed into theta_id) ----
  86: // NOTE (2026-07-11): a v6.1 redesign is planned — report EVERYTHING via a space-filling sweep over the WHOLE
  87: // uncertain set (incl. thesis levers a_V,b_V,s_exp; NO frozen favourable lever) + ceteris-paribus frontier locators
  88: // (per axis: frontier location, possible values, central's best case, probable case ± CI). That rewrite is GATED on
  89: // first anchoring each variable's probable (R_alpha) value to theory/empirics — see research/e4-plausible-anchors.md.
  90: // Current block is the working v6 config; do not treat the swept set below as the final "everything" sweep.
  91: export const EVIDENCE = {
  92:   world:        { N: 1500, K: 150 },   // inside R_alpha for N,K
  93:   probable_nw:  800,                    // worlds for the PROBABLE headline point (with CI)
  94:   sweep_nw:     90,                     // worlds per envelope sample point
  95:   n_env:        400,                    // uniform samples over the ANCHORED scenario envelope (defensible box, not
  96:                                         //   arbitrary raw D_F — sampling uniform over a too-wide D_F would distort the
  97:                                         //   sign fraction). The envelope per knob = [min,max] of the 3 anchored scenarios.
  98:   // Held at base (not varied by the anchored scenarios): computational/cost/value-scale nuisances.
  99:   fixed:        ['N', 'K', 'c_lo', 'c_hi', 'm_q', 's_q', 'sigma', 'sigma_v', 'v_p0', 'phi', 'h'],
 100: };
 101: 
 102: // ---- CLOSED output schema (embargo-critical): additionalProperties:false; cannot express D/C or ratio-parity-1 ----
 103: export const OUTPUT_SCHEMA = {
 104:   $schema: 'http://json-schema.org/draft-07/schema#',
 105:   type: 'object',
 106:   additionalProperties: false,
 107:   required: ['contract_version', 'theta_id', 'pi_deg', 'm_hat', 'ci', 'df_dist_share', 'df_cent_share', 'sign_status', 'materiality_status', 'degeneracy_status', 'numerical_status'],
 108:   properties: {
 109:     contract_version:   { type: 'string' },
 110:     theta_id:           { type: 'string' },
 111:     pi_deg:             { type: 'number', minimum: 0, maximum: 1 },
 112:     m_hat:              { type: 'number' },                 // Σ(D-C)/ΣO over kept worlds, a signed fraction of oracle
 113:     ci:                 { type: 'array', items: { type: 'number' }, minItems: 2, maxItems: 2 },
 114:     df_dist_share:      { type: 'number', minimum: 0, maximum: 1 },  // SIGN over D_F: uniform-VOLUME fraction (space-filling
 115:     df_cent_share:      { type: 'number', minimum: 0, maximum: 1 },  //   MC) where each institution wins — a real volume
 116:     df_par_share:       { type: 'number', minimum: 0, maximum: 1 },  //   fraction, not a corner count
 117:     df_dist_share_se:   { type: 'number', minimum: 0, maximum: 1 },  // Monte-Carlo SE of df_dist_share (binomial)
 118:     m_Ralpha:           { type: 'object' },                 // magnitude by alpha level (measured over joint R_alpha)
 119:     sign_status:        { enum: ['pos', 'neg', 'zero-touching', 'indeterminate'] },
 120:     materiality_status: { enum: ['material', 'negligible', 'uncertain'] },
 121:     degeneracy_status:  { enum: ['ok', 'high', 'degenerate'] },
 122:     numerical_status:   { enum: ['resolved', 'unresolved'] },
 123:   },
 124:   // NOTE: there is deliberately NO field able to carry D/C, a ratio with parity 1, or an institution-performance
 125:   // multiplier. The render adapter additionally rejects the tokens 'x'/'×'/'D/C' in performance context.
 126: };
 127: 
 128: // Tokens the sole render adapter must reject in institution-performance context (ASCII x, Unicode multiplication, ratio).
 129: export const EMBARGO_TOKENS = ['×', 'D/C', 'C/D'];
 130: 
 131: // ---------- validation: fail-closed on unknown / unused ----------
 132: export function knownThetaKeys() { return new Set(Object.keys(THETA)); }
 133: 
 134: // Throw if a config carries any key not registered in THETA (unknown), or (optionally) if a registered key is
 135: // missing (unused-required). Engines call this before running.
 136: export function validateConfig(cfg, { requireAll = true } = {}) {
 137:   const known = knownThetaKeys();
 138:   const bad = Object.keys(cfg).filter((k) => !known.has(k));
 139:   if (bad.length) throw new Error(`[contract] unknown parameter(s) not in THETA: ${bad.join(', ')}`);
 140:   if (requireAll) {
 141:     const missing = [...known].filter((k) => !(k in cfg));
 142:     if (missing.length) throw new Error(`[contract] missing required parameter(s): ${missing.join(', ')}`);
 143:   }
 144:   for (const [k, v] of Object.entries(cfg)) {
 145:     if (typeof v !== 'number' || !Number.isFinite(v)) throw new Error(`[contract] ${k} must be a finite number, got ${v}`);
 146:     const { dm } = THETA[k];
 147:     if (v < dm[0] || v > dm[1]) throw new Error(`[contract] ${k}=${v} outside mathematical domain [${dm[0]}, ${dm[1]}]`);
 148:   }
 149:   return true;
 150: }
 151: 
 152: // Executable-domain validation (fail closed): the printed DGP is only defined on a subset of the scalar box.
 153: // validateConfig checks names + scalar bounds; validateDomain checks the constraints that keep the DGP meaningful.
 154: export function validateDomain(cfg) {
 155:   const bad = [];
 156:   const finite = (k) => { if (!Number.isFinite(cfg[k])) bad.push(`${k} not finite`); };
 157:   for (const k of Object.keys(THETA)) finite(k);
 158:   const intPos = (k, min) => { if (!Number.isInteger(cfg[k]) || cfg[k] < min) bad.push(`${k} must be integer >= ${min}`); };
 159:   intPos('N', 1); intPos('K', 2);
 160:   const pos = (k) => { if (!(cfg[k] > 0)) bad.push(`${k} must be > 0`); };
 161:   pos('a_V'); pos('b_V'); pos('a_r'); pos('b_r');           // Beta shapes must be positive
 162:   pos('p');                                                 // engine divides by p
 163:   if (!(cfg.c_lo > 0)) bad.push('c_lo must be > 0');
 164:   if (!(cfg.c_hi > cfg.c_lo)) bad.push('c_hi must be > c_lo');
 165:   if (!(cfg.phi > 0 && cfg.phi < 1)) bad.push('phi must be in (0,1)');
 166:   const unit = (k) => { if (cfg[k] < 0 || cfg[k] > 1) bad.push(`${k} must be in [0,1]`); };
 167:   unit('p'); unit('beta'); unit('pi_opp'); unit('lambda');
 168:   if (cfg.zeta < -1 || cfg.zeta > 1) bad.push('zeta must be in [-1,1]');   // zeta is a correlation, NOT a unit interval
 169:   const nonneg = (k) => { if (cfg[k] < 0) bad.push(`${k} must be >= 0`); };
 170:   ['s_q', 'sigma', 'mu_opp', 'sigma_e', 'sigma_v', 'sigma_C', 's_exp', 'h'].forEach(nonneg);
 171:   if (bad.length) throw new Error(`[contract] executable-domain violation: ${bad.join('; ')}`);
 172:   return true;
 173: }
 174: 
 175: // Is cfg[k] within its declared expectable band R_alpha? (region membership, for manifests/labels — not fatal)
 176: export function inRalpha(cfg, keys = Object.keys(THETA)) {
 177:   return keys.every((k) => cfg[k] >= THETA[k].ralpha[0] && cfg[k] <= THETA[k].ralpha[1]);
 178: }
 179: 
 180: // FNV-1a hash of an arbitrary JSON-able manifest (no Date/Math.random).
 181: export function resolvedHash(manifest) {
 182:   const s = JSON.stringify(manifest);
 183:   let h = 0x811c9dc5;
 184:   for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 0x01000193) >>> 0; }
 185:   return 'fnv1a-' + h.toString(16).padStart(8, '0');
 186: }
 187: 
 188: // Base config = registered default values.
 189: export function baseConfig() {
 190:   const cfg = {};
 191:   for (const [k, spec] of Object.entries(THETA)) cfg[k] = spec.value;
 192:   return cfg;
 193: }
 194: 
 195: // Deterministic content hash of the frozen sets (so the joint D_F/R_alpha objects and thresholds are pinned before
 196: // any production run). Simple FNV-1a over a canonical JSON — no Date/Math.random.
 197: export function contractHash() {
 198:   const canonical = JSON.stringify({ v: CONTRACT_VERSION, THETA, NUM, CLASSIFY, ALPHA_LEVELS, AGGREGATION, EVIDENCE });
 199:   let h = 0x811c9dc5;
 200:   for (let i = 0; i < canonical.length; i++) {
 201:     h ^= canonical.charCodeAt(i);
 202:     h = Math.imul(h, 0x01000193) >>> 0;
 203:   }
 204:   return 'fnv1a-' + h.toString(16).padStart(8, '0');
 205: }
 206: 
 207: export const directionalKeys = () => Object.entries(THETA).filter(([, s]) => s.kind === 'directional').map(([k]) => k);
 208: export const physicalKeys    = () => Object.entries(THETA).filter(([, s]) => s.kind === 'physical').map(([k]) => k);
