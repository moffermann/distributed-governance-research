import {baseConfig,THETA} from './scripts/simulation/e4-v5/contract.mjs';
import {estimand} from './scripts/simulation/e4-v5/engine.mjs';
import {PROBABLE,SCENARIO_WORLD} from './scripts/simulation/e4-v5/scenario-configs.mjs';
const DOC_C={a_V:1,b_V:1.5,p:.05,a_r:.8,b_r:14,pi_opp:.03,mu_opp:1.5,s_exp:.5,b_H_C:1.2,w:.1,a:0,b:1,beta:.8,lambda:0,zeta:.85,gamma:.3,sigma_e:1.2,sigma_C:.2};
const keys=Object.keys(DOC_C).filter(k=>DOC_C[k]"'!==PROBABLE[k]);
const cfg=t=>{const x={...baseConfig(),...SCENARIO_WORLD,...PROBABLE}; for(const k of keys)x[k]=Math.max(THETA[k].df[0],Math.min(THETA[k].df[1],PROBABLE[k]+t*(DOC_C[k]-PROBABLE[k]))); return x};
function root(seed,nw){let last={t:0,m:estimand(cfg(0),{nWorlds:nw,seed}).m_hat}; const curve=[[0,last.m]]; for(let i=1;i<=20;i++){const t=i/20,m=estimand(cfg(t),{nWorlds:nw,seed}).m_hat;curve.push([t,m]);if(last.m*m<=0){const rt=last.t+(0-last.m)*(t-last.t)/(m-last.m);return {root:rt,curve}}last={t,m}}return {root:null,curve};}
for(const seed of [20260711,1,42,4242,99991]){const r=root(seed,500); console.log(JSON.stringify({seed,root:r.root,points:r.curve.filter((_,i)=>i%4===0||i===r.curve.length-1)}));}
